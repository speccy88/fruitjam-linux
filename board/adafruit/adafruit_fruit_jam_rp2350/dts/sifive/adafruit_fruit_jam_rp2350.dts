/dts-v1/;

/ {
	#address-cells = <1>;
	#size-cells = <1>;
	compatible = "adafruit,fruit-jam-rp2350", "raspberrypi,rp2350", "riscv-minimal-nommu";
	model = "Adafruit Fruit Jam RP2350B Hazard3";

	aliases {
		serial0 = &uart1;
		i2c0 = &i2c_gpio0;
		spi0 = &spi1; /* Preserve AirLift as /dev/spidev0.0. */
		spi1 = &spi0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
		bootargs = "earlycon=pl011,mmio32,0x40078000 console=ttyAMA0 console=ttyGS0 root=mtd:cramfs rootfstype=cramfs ro";
	};

	clk_sys: clk-sys {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <150000000>;
	};

	flash@10000000 {
		compatible = "phram"; /* XIP flash mapped into physical address space */
		reg = <0x10000000 0x1000000>; /* 16 MiB QSPI flash */

		partitions {
			#address-cells = <1>;
			#size-cells = <1>;
			compatible = "fixed-partitions";

			partition@600000 {
				label = "cramfs";
				reg = <0x600000 0xa00000>; /* rootfs.cramfs at 6 MiB, up to end of 16 MiB flash */
				read-only;
			};
		};
	};

	fruitjam_pins: fruitjam-pins {
		compatible = "adafruit,fruit-jam-rp2350-pinmap";
		adafruit,button-gpios = <0 4 5>;
		adafruit,red-led-gpio = <29>;
		adafruit,neopixel-gpio = <32>;
		adafruit,usb-host-gpios = <1 2 11>;
		adafruit,peripheral-reset-gpio = <22>;
		adafruit,i2c-gpios = <20 21>;
		adafruit,i2s-gpios = <24 25 26 27 23>;
		adafruit,dvi-gpios = <12 13 14 15 16 17 18 19>;
		adafruit,sd-spi-gpios = <34 35 36 39 33>;
	};

	i2c_gpio0: i2c-gpio0 {
		compatible = "i2c-gpio";
		sda-gpios = <&gpio0 20 6>; /* active-high open-drain */
		scl-gpios = <&gpio0 21 6>; /* active-high open-drain */
		i2c-gpio,delay-us = <5>; /* ~100 kHz */
		#address-cells = <1>;
		#size-cells = <0>;
		status = "okay";
	};

	memory@11000000 {
		device_type = "memory";
		reg = <0x11000000 0x800000>; /* 8 MiB external PSRAM */
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;
		timebase-frequency = <1000000>;

		cpu0: cpu@0 {
			reg = <0>;
			device_type = "cpu";
			compatible = "riscv";
			riscv,isa = "rv32ima";
			riscv,isa-base = "rv32i";
			riscv,isa-extensions = "i", "m", "a";
			mmu-type = "riscv,none";
			status = "okay";

			cpu0_intc: interrupt-controller {
				#interrupt-cells = <1>;
				#address-cells = <1>;
				interrupt-controller;
				compatible = "riscv,cpu-intc";
			};
		};
	};

	soc {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "simple-bus";
		ranges;

		/* Fruit Jam's labeled TX/RX header pins are UART1 on GPIO8/GPIO9. */
		uart1: serial@40078000 {
			compatible = "arm,sbsa-uart";
			current-speed = <115200>;
			interrupt-parent = <&plic0>;
			interrupts = <34>;
			reg = <0x40078000 0x100>;
			status = "okay";
		};

		usb0: usb@50100000 {
			compatible = "raspberrypi,rp2350-usb", "raspberrypi,rp2040-usb";
			reg = <0x50100000 0x1000>,
			      <0x50110000 0x118>,
			      <0x40020000 0x00c>;
			reg-names = "dpram", "regs", "resets";
			interrupt-parent = <&plic0>;
			interrupts = <14>;
			status = "okay";
		};

		gpio0: gpio@d0000000 {
			compatible = "raspberrypi,rp2350-sio-gpio";
			reg = <0xd0000000 0x1000>,
			      <0x40028000 0x1000>,
			      <0x40038000 0x1000>;
			reg-names = "sio", "io-bank0", "pads-bank0";
			gpio-controller;
			#gpio-cells = <2>;
			ngpios = <46>; /* GPIO47 is PSRAM CS1 and must not be exported. */
			status = "okay";
		};

		adc0: adc@400a0000 {
			compatible = "adafruit,fruit-jam-rp2350-adc";
			reg = <0x400a0000 0x100>,
			      <0x40020000 0x00c>,
			      <0x40028000 0x200>,
			      <0x40038000 0x100>;
			reg-names = "adc", "resets", "io-bank0", "pads-bank0";
			raspberrypi,adc-base-gpio = <40>;
			status = "okay";
		};

			neopixels: neopixels@50200000 {
				compatible = "adafruit,fruit-jam-rp2350-neopixel";
				reg = <0x50200000 0x1000>,
			      <0x40020000 0x00c>,
			      <0x40028000 0x200>,
			      <0x40038000 0x100>;
			reg-names = "pio", "resets", "io-bank0", "pads-bank0";
			raspberrypi,pio = <0>;
			raspberrypi,sm = <0>;
			raspberrypi,gpio = <32>;
			raspberrypi,gpio-base = <16>;
			raspberrypi,num-leds = <5>;
			raspberrypi,clk-sys-hz = <150000000>;
				status = "okay";
			};

			airlift_gpio: airlift-gpio@40028000 {
				compatible = "adafruit,fruit-jam-rp2350-airlift-gpio";
				reg = <0xd0000000 0x1000>,
				      <0x40028000 0x1000>,
				      <0x40038000 0x1000>;
				reg-names = "sio", "io-bank0", "pads-bank0";
				status = "okay";
			};

			audio_clock: audio-clock@50300000 {
				compatible = "adafruit,fruit-jam-rp2350-audio-clock";
				reg = <0x50300000 0x1000>,
				      <0x40020000 0x00c>,
				      <0x40028000 0x200>,
				      <0x40038000 0x100>;
				reg-names = "pio", "resets", "io-bank0", "pads-bank0";
				raspberrypi,pio = <1>;
				raspberrypi,sm = <1>;
				raspberrypi,mclk-sm = <0>;
				raspberrypi,din-gpio = <24>;
				raspberrypi,mclk-gpio = <25>;
				raspberrypi,bclk-gpio = <26>;
				raspberrypi,ws-gpio = <27>;
				raspberrypi,gpio-base = <16>;
				raspberrypi,clk-sys-hz = <150000000>;
				raspberrypi,mclk-hz = <15000000>;
				status = "okay";
			};

			dvi: dvi@400c0000 {
				compatible = "adafruit,fruit-jam-rp2350-dvi";
				reg = <0x400c0000 0x100>,
				      <0x50600000 0x100>,
				      <0x50000000 0x1000>,
				      <0x40020000 0x00c>,
				      <0x40028000 0x200>,
				      <0x40038000 0x100>,
				      <0x40068000 0x100>,
				      <0x40010000 0x100>;
				reg-names = "hstx-ctrl", "hstx-fifo", "dma",
					    "resets", "io-bank0", "pads-bank0",
					    "busctrl", "clocks";
				interrupt-parent = <&plic0>;
				interrupts = <10>;
				status = "okay";
			};

			spi0: spi@40080000 {
				compatible = "arm,pl022", "arm,primecell";
				arm,primecell-periphid = <0x00041022>;
				reg = <0x40080000 0x1000>;
				interrupt-parent = <&plic0>;
				interrupts = <31>;
				clocks = <&clk_sys>, <&clk_sys>;
				clock-names = "sspclk", "apb_pclk";
				#address-cells = <1>;
				#size-cells = <0>;
				num-cs = <1>;
				cs-gpios = <&gpio0 39 1>;
				status = "okay";

				sdcard@0 {
					compatible = "mmc-spi-slot";
					reg = <0>;
					spi-max-frequency = <8000000>;
					broken-cd;
					disable-wp;
				};
			};

			spi1: spi@40088000 {
				compatible = "arm,pl022", "arm,primecell";
				arm,primecell-periphid = <0x00041022>;
				reg = <0x40088000 0x1000>;
				interrupt-parent = <&plic0>;
				interrupts = <32>;
				clocks = <&clk_sys>, <&clk_sys>;
				clock-names = "sspclk", "apb_pclk";
				#address-cells = <1>;
				#size-cells = <0>;
				status = "okay";

				airlift@0 {
					compatible = "silabs,em3581";
					reg = <0>;
					spi-max-frequency = <8000000>;
				};
			};

			plic0: interrupt-controller@0 {
				reg = <0x0 0x0>;
				interrupts-extended = <&cpu0_intc 11>;
			interrupt-controller;
			compatible = "generic,simple-intc";
			#address-cells = <0x00>;
			#interrupt-cells = <0x01>;
		};

		clint: clint@d0000000 {
			interrupts-extended = <&cpu0_intc 3>,
					      <&cpu0_intc 7>;
			reg = <0xd0000000 0x400>;
			compatible = "riscv,clint0";
		};
	};
};
