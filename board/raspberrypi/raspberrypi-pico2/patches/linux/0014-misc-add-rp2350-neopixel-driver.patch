From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Wed, 10 Jun 2026 04:20:00 -0400
Subject: [PATCH] misc: add RP2350 PIO NeoPixel driver

Add a small RP2350-specific misc driver for the Adafruit Fruit Jam's
onboard WS2812/NeoPixel chain.  The driver programs PIO0 state machine 0
with the standard four-instruction WS2812 program, selects the RP2350B
high-GPIO PIO base, and exposes a simple text interface at /dev/neopixels.

Supported commands are:

  clear
  fill R G B
  set INDEX R G B
  write
  test

This is intentionally a minimal board bring-up interface.  It avoids Linux
CPU bit-banging; waveform timing is generated by the PIO state machine.
---
 drivers/misc/Kconfig           |  11 +
 drivers/misc/Makefile          |   1 +
 drivers/misc/rp2350_neopixel.c | 574 ++++++++++++++++++++++++++++++++
 3 files changed, 586 insertions(+)
 create mode 100644 drivers/misc/rp2350_neopixel.c

diff --git a/drivers/misc/Kconfig b/drivers/misc/Kconfig
index 41ed7d3dd99d..0f58d5b5b8a1 100644
--- a/drivers/misc/Kconfig
+++ b/drivers/misc/Kconfig
@@ -51,6 +51,17 @@ config DUMMY_IRQ
 	  The sole purpose of this module is to help with debugging of systems on
 	  which spurious IRQs would happen on disabled IRQ vector.

+config RP2350_NEOPIXEL
+	tristate "RP2350 PIO NeoPixel misc device"
+	depends on OF && HAS_IOMEM
+	help
+	  Say Y here to expose a small /dev/neopixels text interface backed
+	  by an RP2350 PIO state machine.  This is intended for board
+	  bring-up on small onboard WS2812/NeoPixel chains, such as the
+	  five LEDs on the Adafruit Fruit Jam RP2350B.
+
+	  If unsure, say N.
+
 config IBM_ASM
 	tristate "Device driver for IBM RSA service processor"
 	depends on X86 && PCI && INPUT
diff --git a/drivers/misc/Makefile b/drivers/misc/Makefile
index 87b54c0934b9..510af3884413 100644
--- a/drivers/misc/Makefile
+++ b/drivers/misc/Makefile
@@ -7,6 +7,7 @@
 obj-$(CONFIG_IBM_ASM)		+= ibmasm/
 obj-$(CONFIG_IBMVMC)		+= ibmvmc.o
 obj-$(CONFIG_AD525X_DPOT)	+= ad525x_dpot.o
+obj-$(CONFIG_RP2350_NEOPIXEL)	+= rp2350_neopixel.o
 obj-$(CONFIG_AD525X_DPOT_I2C)	+= ad525x_dpot-i2c.o
 obj-$(CONFIG_AD525X_DPOT_SPI)	+= ad525x_dpot-spi.o
 obj-$(CONFIG_ATMEL_SSC)		+= atmel-ssc.o
diff --git a/drivers/misc/rp2350_neopixel.c b/drivers/misc/rp2350_neopixel.c
new file mode 100644
index 000000000000..d36c8808ca6e
--- /dev/null
+++ b/drivers/misc/rp2350_neopixel.c
@@ -0,0 +1,574 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Minimal RP2350 PIO-backed NeoPixel/WS2812 driver.
+ *
+ * This board bring-up driver exposes /dev/neopixels with a tiny text command
+ * interface.  It is not a generic LED class driver yet; its purpose is to give
+ * no-MMU RP2350 Linux userspace a real PIO waveform generator instead of
+ * timing-sensitive CPU bit-banging.
+ */
+
+#include <linux/bitops.h>
+#include <linux/delay.h>
+#include <linux/device.h>
+#include <linux/err.h>
+#include <linux/fs.h>
+#include <linux/io.h>
+#include <linux/kernel.h>
+#include <linux/miscdevice.h>
+#include <linux/module.h>
+#include <linux/mutex.h>
+#include <linux/of.h>
+#include <linux/of_device.h>
+#include <linux/platform_device.h>
+#include <linux/slab.h>
+#include <linux/string.h>
+#include <linux/uaccess.h>
+
+#define RP2350_PIO_CTRL		0x000
+#define RP2350_PIO_FSTAT	0x004
+#define RP2350_PIO_FDEBUG	0x008
+#define RP2350_PIO_TXF(sm)	(0x010 + ((sm) * 4))
+#define RP2350_PIO_INSTR_MEM	0x048
+#define RP2350_PIO_SM_BASE(sm)	(0x0c8 + ((sm) * 0x18))
+#define RP2350_PIO_SM_CLKDIV	0x00
+#define RP2350_PIO_SM_EXECCTRL	0x04
+#define RP2350_PIO_SM_SHIFTCTRL	0x08
+#define RP2350_PIO_SM_INSTR	0x10
+#define RP2350_PIO_SM_PINCTRL	0x14
+#define RP2350_PIO_GPIOBASE	0x168
+
+#define RP2350_RESETS_RESET	0x000
+#define RP2350_RESETS_DONE	0x008
+#define RP2350_RESET_PIO0	11
+#define RP2350_RESET_PIO1	12
+#define RP2350_RESET_PIO2	13
+
+#define RP2350_IO_GPIO_CTRL(gpio)	(0x004 + ((gpio) * 8))
+#define RP2350_PADS_GPIO(gpio)		(0x004 + ((gpio) * 4))
+
+#define RP2350_GPIO_FUNC_PIO0	6
+#define RP2350_GPIO_FUNC_PIO1	7
+#define RP2350_GPIO_FUNC_PIO2	8
+#define RP2350_PADS_DRIVE_4MA	BIT(4)
+
+#define RP2350_PIO_CTRL_SM_ENABLE(sm)	BIT(sm)
+#define RP2350_PIO_CTRL_SM_RESTART(sm)	BIT(4 + (sm))
+#define RP2350_PIO_CTRL_CLKDIV_RESTART(sm) BIT(8 + (sm))
+#define RP2350_PIO_FSTAT_TXFULL(sm)	BIT(16 + (sm))
+#define RP2350_PIO_FSTAT_TXEMPTY(sm)	BIT(24 + (sm))
+#define RP2350_PIO_FDEBUG_TXSTALL(sm)	BIT(24 + (sm))
+#define RP2350_PIO_FDEBUG_TXOVER(sm)	BIT(16 + (sm))
+#define RP2350_PIO_FDEBUG_RXUNDER(sm)	BIT(8 + (sm))
+#define RP2350_PIO_FDEBUG_RXSTALL(sm)	BIT(sm)
+
+#define RP2350_PIO_EXECCTRL_WRAP_TOP(v)	(((v) & 0x1f) << 12)
+#define RP2350_PIO_EXECCTRL_WRAP_BOTTOM(v) (((v) & 0x1f) << 7)
+
+#define RP2350_PIO_SHIFTCTRL_FJOIN_TX	BIT(30)
+#define RP2350_PIO_SHIFTCTRL_FJOIN_RX	BIT(31)
+#define RP2350_PIO_SHIFTCTRL_PULL_THRESH(v) (((v) & 0x1f) << 25)
+#define RP2350_PIO_SHIFTCTRL_AUTOPULL	BIT(17)
+
+#define RP2350_PIO_PINCTRL_SIDESET_COUNT(v) (((v) & 0x7) << 29)
+#define RP2350_PIO_PINCTRL_SET_COUNT(v)	(((v) & 0x7) << 26)
+#define RP2350_PIO_PINCTRL_OUT_COUNT(v)	(((v) & 0x3f) << 20)
+#define RP2350_PIO_PINCTRL_SIDESET_BASE(v) (((v) & 0x1f) << 10)
+#define RP2350_PIO_PINCTRL_SET_BASE(v)	(((v) & 0x1f) << 5)
+#define RP2350_PIO_PINCTRL_OUT_BASE(v)	((v) & 0x1f)
+
+#define RP2350_WS2812_BITS_PER_LED	24
+#define RP2350_WS2812_CYCLES_PER_BIT	10
+#define RP2350_WS2812_BIT_HZ		800000
+#define RP2350_WS2812_RESET_US		80
+#define RP2350_NEOPIXEL_MAX_LEDS	256
+#define RP2350_NEOPIXEL_MAX_WRITE	1024
+#define RP2350_NEOPIXEL_LINE_MAX	128
+
+/*
+ * Generated from the Pico SDK WS2812 PIO program:
+ *
+ * .program ws2812
+ * .side_set 1
+ * .wrap_target
+ *     out x, 1        side 0 [2]
+ *     jmp !x, do_zero side 1 [1]
+ *     jmp bitloop     side 1 [4]
+ * do_zero:
+ *     nop             side 0 [4]
+ * .wrap
+ */
+static const u16 rp2350_ws2812_program[] = {
+	0x6221, 0x1123, 0x1400, 0xa442,
+};
+
+struct rp2350_neopixel_rgb {
+	u8 r;
+	u8 g;
+	u8 b;
+};
+
+struct rp2350_neopixel {
+	struct device *dev;
+	struct miscdevice miscdev;
+	struct mutex lock;
+	void __iomem *pio;
+	void __iomem *resets;
+	void __iomem *io_bank0;
+	void __iomem *pads_bank0;
+	struct rp2350_neopixel_rgb *pixels;
+	u32 num_leds;
+	u32 pio_index;
+	u32 sm;
+	u32 gpio;
+	u32 gpio_base;
+	u32 clk_sys_hz;
+	u32 local_gpio;
+	char line[RP2350_NEOPIXEL_LINE_MAX];
+	size_t line_len;
+};
+
+static void rp2350_np_sm_disable(struct rp2350_neopixel *np)
+{
+	u32 ctrl = readl(np->pio + RP2350_PIO_CTRL);
+
+	ctrl &= ~RP2350_PIO_CTRL_SM_ENABLE(np->sm);
+	writel(ctrl, np->pio + RP2350_PIO_CTRL);
+}
+
+static void rp2350_np_sm_restart(struct rp2350_neopixel *np)
+{
+	u32 ctrl = readl(np->pio + RP2350_PIO_CTRL);
+
+	ctrl |= RP2350_PIO_CTRL_SM_RESTART(np->sm);
+	ctrl |= RP2350_PIO_CTRL_CLKDIV_RESTART(np->sm);
+	writel(ctrl, np->pio + RP2350_PIO_CTRL);
+}
+
+static void rp2350_np_sm_enable(struct rp2350_neopixel *np)
+{
+	u32 ctrl = readl(np->pio + RP2350_PIO_CTRL);
+
+	ctrl |= RP2350_PIO_CTRL_SM_ENABLE(np->sm);
+	writel(ctrl, np->pio + RP2350_PIO_CTRL);
+}
+
+static void rp2350_np_reset_pio(struct rp2350_neopixel *np)
+{
+	u32 bit = BIT(RP2350_RESET_PIO0 + np->pio_index);
+	u32 reset;
+	int i;
+
+	reset = readl(np->resets + RP2350_RESETS_RESET);
+	reset &= ~bit;
+	writel(reset, np->resets + RP2350_RESETS_RESET);
+
+	for (i = 0; i < 100000; i++) {
+		if (readl(np->resets + RP2350_RESETS_DONE) & bit)
+			return;
+		cpu_relax();
+	}
+
+	dev_warn(np->dev, "PIO%u reset-done timeout\n", np->pio_index);
+}
+
+static u32 rp2350_np_clkdiv(struct rp2350_neopixel *np)
+{
+	u64 denom = RP2350_WS2812_BIT_HZ * RP2350_WS2812_CYCLES_PER_BIT;
+	u64 scaled = div64_u64((u64)np->clk_sys_hz * 256 + denom / 2, denom);
+	u32 div_int = scaled >> 8;
+	u32 div_frac = scaled & 0xff;
+
+	if (!div_int)
+		div_int = 1;
+	if (div_int > 0xffff)
+		div_int = 0xffff;
+
+	return (div_int << 16) | (div_frac << 8);
+}
+
+static void rp2350_np_configure_gpio(struct rp2350_neopixel *np)
+{
+	u32 func = RP2350_GPIO_FUNC_PIO0 + np->pio_index;
+
+	writel(RP2350_PADS_DRIVE_4MA,
+	       np->pads_bank0 + RP2350_PADS_GPIO(np->gpio));
+	writel(func, np->io_bank0 + RP2350_IO_GPIO_CTRL(np->gpio));
+}
+
+static void rp2350_np_load_program(struct rp2350_neopixel *np)
+{
+	int i;
+
+	for (i = 0; i < ARRAY_SIZE(rp2350_ws2812_program); i++)
+		writel(rp2350_ws2812_program[i],
+		       np->pio + RP2350_PIO_INSTR_MEM + i * 4);
+}
+
+static void rp2350_np_clear_fifos(struct rp2350_neopixel *np)
+{
+	void __iomem *sm = np->pio + RP2350_PIO_SM_BASE(np->sm);
+
+	writel(RP2350_PIO_SHIFTCTRL_FJOIN_RX,
+	       sm + RP2350_PIO_SM_SHIFTCTRL);
+	writel(0, sm + RP2350_PIO_SM_SHIFTCTRL);
+}
+
+static void rp2350_np_configure_sm(struct rp2350_neopixel *np)
+{
+	void __iomem *sm = np->pio + RP2350_PIO_SM_BASE(np->sm);
+	u32 execctrl;
+	u32 shiftctrl;
+	u32 pinctrl;
+
+	rp2350_np_sm_disable(np);
+	rp2350_np_clear_fifos(np);
+
+	writel(0, np->pio + RP2350_PIO_GPIOBASE);
+	writel(np->gpio_base, np->pio + RP2350_PIO_GPIOBASE);
+
+	execctrl = RP2350_PIO_EXECCTRL_WRAP_TOP(3) |
+		   RP2350_PIO_EXECCTRL_WRAP_BOTTOM(0);
+	shiftctrl = RP2350_PIO_SHIFTCTRL_FJOIN_TX |
+		    RP2350_PIO_SHIFTCTRL_PULL_THRESH(24) |
+		    RP2350_PIO_SHIFTCTRL_AUTOPULL;
+	pinctrl = RP2350_PIO_PINCTRL_SIDESET_COUNT(1) |
+		  RP2350_PIO_PINCTRL_SET_COUNT(1) |
+		  RP2350_PIO_PINCTRL_OUT_COUNT(1) |
+		  RP2350_PIO_PINCTRL_SIDESET_BASE(np->local_gpio) |
+		  RP2350_PIO_PINCTRL_SET_BASE(np->local_gpio) |
+		  RP2350_PIO_PINCTRL_OUT_BASE(np->local_gpio);
+
+	writel(rp2350_np_clkdiv(np), sm + RP2350_PIO_SM_CLKDIV);
+	writel(execctrl, sm + RP2350_PIO_SM_EXECCTRL);
+	writel(shiftctrl, sm + RP2350_PIO_SM_SHIFTCTRL);
+	writel(pinctrl, sm + RP2350_PIO_SM_PINCTRL);
+
+	rp2350_np_sm_restart(np);
+	writel(RP2350_PIO_FDEBUG_TXSTALL(np->sm) |
+	       RP2350_PIO_FDEBUG_TXOVER(np->sm) |
+	       RP2350_PIO_FDEBUG_RXUNDER(np->sm) |
+	       RP2350_PIO_FDEBUG_RXSTALL(np->sm),
+	       np->pio + RP2350_PIO_FDEBUG);
+
+	/* Forced SET PINDIRS, 1 so the PIO owns the output enable. */
+	writel(0xe081, sm + RP2350_PIO_SM_INSTR);
+	/* Forced SET PINS, 0 keeps the idle line low until data is queued. */
+	writel(0xe000, sm + RP2350_PIO_SM_INSTR);
+	rp2350_np_sm_enable(np);
+}
+
+static int rp2350_np_wait_tx_space(struct rp2350_neopixel *np)
+{
+	int i;
+
+	for (i = 0; i < 100000; i++) {
+		if (!(readl(np->pio + RP2350_PIO_FSTAT) &
+		      RP2350_PIO_FSTAT_TXFULL(np->sm)))
+			return 0;
+		cpu_relax();
+	}
+
+	return -ETIMEDOUT;
+}
+
+static int rp2350_np_wait_tx_empty(struct rp2350_neopixel *np)
+{
+	int i;
+
+	for (i = 0; i < 100000; i++) {
+		if (readl(np->pio + RP2350_PIO_FSTAT) &
+		    RP2350_PIO_FSTAT_TXEMPTY(np->sm))
+			return 0;
+		cpu_relax();
+	}
+
+	return -ETIMEDOUT;
+}
+
+static int rp2350_np_show(struct rp2350_neopixel *np)
+{
+	u32 frame_us = np->num_leds * 30 + RP2350_WS2812_RESET_US;
+	u32 i;
+	int ret;
+
+	rp2350_np_configure_sm(np);
+
+	for (i = 0; i < np->num_leds; i++) {
+		u32 grb = ((u32)np->pixels[i].g << 24) |
+			  ((u32)np->pixels[i].r << 16) |
+			  ((u32)np->pixels[i].b << 8);
+
+		ret = rp2350_np_wait_tx_space(np);
+		if (ret)
+			return ret;
+		writel(grb, np->pio + RP2350_PIO_TXF(np->sm));
+	}
+
+	ret = rp2350_np_wait_tx_empty(np);
+	if (ret)
+		return ret;
+
+	udelay(frame_us);
+	return 0;
+}
+
+static void rp2350_np_fill(struct rp2350_neopixel *np, u8 r, u8 g, u8 b)
+{
+	u32 i;
+
+	for (i = 0; i < np->num_leds; i++) {
+		np->pixels[i].r = r;
+		np->pixels[i].g = g;
+		np->pixels[i].b = b;
+	}
+}
+
+static int rp2350_np_parse_rgb(unsigned int r, unsigned int g, unsigned int b,
+			       u8 *rr, u8 *gg, u8 *bb)
+{
+	if (r > 255 || g > 255 || b > 255)
+		return -EINVAL;
+
+	*rr = r;
+	*gg = g;
+	*bb = b;
+	return 0;
+}
+
+static int rp2350_np_run_line(struct rp2350_neopixel *np, char *line)
+{
+	unsigned int idx, r, g, b;
+	u8 rr, gg, bb;
+	int ret;
+
+	strim(line);
+	if (!*line || *line == '#')
+		return 0;
+
+	if (!strcmp(line, "write"))
+		return rp2350_np_show(np);
+
+	if (!strcmp(line, "clear")) {
+		rp2350_np_fill(np, 0, 0, 0);
+		return rp2350_np_show(np);
+	}
+
+	if (!strcmp(line, "test")) {
+		rp2350_np_fill(np, 0, 0, 0);
+		if (np->num_leds > 0)
+			np->pixels[0] = (struct rp2350_neopixel_rgb){ 24, 0, 0 };
+		if (np->num_leds > 1)
+			np->pixels[1] = (struct rp2350_neopixel_rgb){ 24, 12, 0 };
+		if (np->num_leds > 2)
+			np->pixels[2] = (struct rp2350_neopixel_rgb){ 0, 24, 0 };
+		if (np->num_leds > 3)
+			np->pixels[3] = (struct rp2350_neopixel_rgb){ 0, 0, 24 };
+		if (np->num_leds > 4)
+			np->pixels[4] = (struct rp2350_neopixel_rgb){ 12, 0, 24 };
+		return rp2350_np_show(np);
+	}
+
+	if (sscanf(line, "fill %u %u %u", &r, &g, &b) == 3) {
+		ret = rp2350_np_parse_rgb(r, g, b, &rr, &gg, &bb);
+		if (ret)
+			return ret;
+		rp2350_np_fill(np, rr, gg, bb);
+		return 0;
+	}
+
+	if (sscanf(line, "set %u %u %u %u", &idx, &r, &g, &b) == 4) {
+		if (idx >= np->num_leds)
+			return -ERANGE;
+		ret = rp2350_np_parse_rgb(r, g, b, &rr, &gg, &bb);
+		if (ret)
+			return ret;
+		np->pixels[idx].r = rr;
+		np->pixels[idx].g = gg;
+		np->pixels[idx].b = bb;
+		return 0;
+	}
+
+	dev_warn(np->dev, "unknown neopixel command: %s\n", line);
+	return -EINVAL;
+}
+
+static int rp2350_np_consume_byte(struct rp2350_neopixel *np, char ch)
+{
+	int ret;
+
+	if (ch == '\r')
+		return 0;
+
+	if (ch == '\n') {
+		np->line[np->line_len] = '\0';
+		ret = rp2350_np_run_line(np, np->line);
+		np->line_len = 0;
+		return ret;
+	}
+
+	if (np->line_len >= sizeof(np->line) - 1) {
+		np->line_len = 0;
+		return -E2BIG;
+	}
+
+	np->line[np->line_len++] = ch;
+	return 0;
+}
+
+static ssize_t rp2350_np_write(struct file *file, const char __user *ubuf,
+			       size_t count, loff_t *ppos)
+{
+	struct rp2350_neopixel *np = file->private_data;
+	char *buf;
+	size_t i;
+	int ret = 0;
+
+	if (!count)
+		return 0;
+	if (count > RP2350_NEOPIXEL_MAX_WRITE)
+		return -E2BIG;
+
+	buf = memdup_user_nul(ubuf, count);
+	if (IS_ERR(buf))
+		return PTR_ERR(buf);
+
+	mutex_lock(&np->lock);
+	for (i = 0; i < count; i++) {
+		ret = rp2350_np_consume_byte(np, buf[i]);
+		if (ret)
+			break;
+	}
+	mutex_unlock(&np->lock);
+
+	kfree(buf);
+	return ret ? ret : count;
+}
+
+static int rp2350_np_open(struct inode *inode, struct file *file)
+{
+	struct miscdevice *miscdev = file->private_data;
+	struct rp2350_neopixel *np =
+		container_of(miscdev, struct rp2350_neopixel, miscdev);
+
+	file->private_data = np;
+	return nonseekable_open(inode, file);
+}
+
+static const struct file_operations rp2350_np_fops = {
+	.owner = THIS_MODULE,
+	.open = rp2350_np_open,
+	.write = rp2350_np_write,
+	.llseek = noop_llseek,
+};
+
+static int rp2350_np_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct rp2350_neopixel *np;
+	struct resource *res;
+	int ret;
+
+	np = devm_kzalloc(dev, sizeof(*np), GFP_KERNEL);
+	if (!np)
+		return -ENOMEM;
+
+	np->dev = dev;
+	mutex_init(&np->lock);
+
+	np->pio = devm_platform_ioremap_resource_byname(pdev, "pio");
+	if (IS_ERR(np->pio))
+		return PTR_ERR(np->pio);
+	res = platform_get_resource_byname(pdev, IORESOURCE_MEM, "resets");
+	if (!res)
+		return dev_err_probe(dev, -ENODEV, "missing resets resource\n");
+	np->resets = devm_ioremap(dev, res->start, resource_size(res));
+	if (!np->resets)
+		return dev_err_probe(dev, -ENOMEM, "map shared resets\n");
+	np->io_bank0 = devm_platform_ioremap_resource_byname(pdev, "io-bank0");
+	if (IS_ERR(np->io_bank0))
+		return PTR_ERR(np->io_bank0);
+	np->pads_bank0 = devm_platform_ioremap_resource_byname(pdev, "pads-bank0");
+	if (IS_ERR(np->pads_bank0))
+		return PTR_ERR(np->pads_bank0);
+
+	np->pio_index = 0;
+	np->sm = 0;
+	np->gpio = 32;
+	np->gpio_base = 16;
+	np->num_leds = 5;
+	np->clk_sys_hz = 150000000;
+
+	of_property_read_u32(dev->of_node, "raspberrypi,pio", &np->pio_index);
+	of_property_read_u32(dev->of_node, "raspberrypi,sm", &np->sm);
+	of_property_read_u32(dev->of_node, "raspberrypi,gpio", &np->gpio);
+	of_property_read_u32(dev->of_node, "raspberrypi,gpio-base", &np->gpio_base);
+	of_property_read_u32(dev->of_node, "raspberrypi,num-leds", &np->num_leds);
+	of_property_read_u32(dev->of_node, "raspberrypi,clk-sys-hz", &np->clk_sys_hz);
+
+	if (np->pio_index > 2 || np->sm > 3)
+		return dev_err_probe(dev, -EINVAL, "invalid PIO%u SM%u\n",
+				     np->pio_index, np->sm);
+	if (np->gpio < np->gpio_base || np->gpio >= np->gpio_base + 32)
+		return dev_err_probe(dev, -EINVAL,
+				     "GPIO%u outside PIO GPIO base %u\n",
+				     np->gpio, np->gpio_base);
+	if (!np->num_leds || np->num_leds > RP2350_NEOPIXEL_MAX_LEDS)
+		return dev_err_probe(dev, -EINVAL, "invalid LED count %u\n",
+				     np->num_leds);
+
+	np->local_gpio = np->gpio - np->gpio_base;
+	np->pixels = devm_kcalloc(dev, np->num_leds, sizeof(*np->pixels),
+				  GFP_KERNEL);
+	if (!np->pixels)
+		return -ENOMEM;
+
+	rp2350_np_reset_pio(np);
+	rp2350_np_configure_gpio(np);
+	rp2350_np_load_program(np);
+	rp2350_np_fill(np, 0, 0, 0);
+	rp2350_np_show(np);
+
+	np->miscdev.minor = MISC_DYNAMIC_MINOR;
+	np->miscdev.name = "neopixels";
+	np->miscdev.fops = &rp2350_np_fops;
+	np->miscdev.parent = dev;
+	np->miscdev.mode = 0666;
+
+	ret = misc_register(&np->miscdev);
+	if (ret)
+		return dev_err_probe(dev, ret, "register /dev/neopixels\n");
+
+	platform_set_drvdata(pdev, np);
+	dev_info(dev, "registered /dev/neopixels on PIO%u SM%u GPIO%u (%u LEDs)\n",
+		 np->pio_index, np->sm, np->gpio, np->num_leds);
+	return 0;
+}
+
+static void rp2350_np_remove(struct platform_device *pdev)
+{
+	struct rp2350_neopixel *np = platform_get_drvdata(pdev);
+
+	mutex_lock(&np->lock);
+	rp2350_np_fill(np, 0, 0, 0);
+	rp2350_np_show(np);
+	rp2350_np_sm_disable(np);
+	mutex_unlock(&np->lock);
+	misc_deregister(&np->miscdev);
+}
+
+static const struct of_device_id rp2350_np_of_match[] = {
+	{ .compatible = "adafruit,fruit-jam-rp2350-neopixel" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, rp2350_np_of_match);
+
+static struct platform_driver rp2350_np_driver = {
+	.probe = rp2350_np_probe,
+	.remove = rp2350_np_remove,
+	.driver = {
+		.name = "rp2350-neopixel",
+		.of_match_table = rp2350_np_of_match,
+	},
+};
+module_platform_driver(rp2350_np_driver);
+
+MODULE_DESCRIPTION("RP2350 PIO NeoPixel misc device");
+MODULE_AUTHOR("Codex");
+MODULE_LICENSE("GPL");
