 	uh->pio_ready = true;
-	return 0;
+	return fj_usbhost_pio_configure_sms(uh);
+}
+
+static u8 fj_usbhost_crc5_token(u16 data)
+{
+	u8 crc = 0x1f;
+	int i;
+
+	for (i = 0; i < 11; i++) {
+		bool bit = (data ^ crc) & 1;
+
+		crc >>= 1;
+		if (bit)
+			crc ^= 0x14;
+		data >>= 1;
+	}
+
+	return crc ^ 0x1f;
 }
 
+static u8 fj_usbhost_encode_tx(const u8 *packet, u8 packet_len, u8 *encoded)
+{
+	u16 bit_idx = 0;
+	int current_state = 1;
+	int bit_stuffing = 6;
+	int idx;
+
+	memset(encoded, 0, FJ_USBHOST_TX_ENCODED_MAX);
+	for (idx = 0; idx < packet_len; idx++) {
+		u8 data_byte = packet[idx];
+		int bit;
+
+		for (bit = 0; bit < 8; bit++) {
+			u8 byte_idx = bit_idx >> 2;
+
+			encoded[byte_idx] <<= 2;
+			if (data_byte & BIT(bit)) {
+				encoded[byte_idx] |= current_state ?
+					FJ_USB_TX_ENCODED_K : FJ_USB_TX_ENCODED_J;
+				bit_stuffing--;
+			} else {
+				encoded[byte_idx] |= current_state ?
+					FJ_USB_TX_ENCODED_J : FJ_USB_TX_ENCODED_K;
+				current_state = !current_state;
+				bit_stuffing = 6;
+			}
+			bit_idx++;
+
+			if (!bit_stuffing) {
+				byte_idx = bit_idx >> 2;
+				encoded[byte_idx] <<= 2;
+				encoded[byte_idx] |= current_state ?
+					FJ_USB_TX_ENCODED_J : FJ_USB_TX_ENCODED_K;
+				current_state = !current_state;
+				bit_stuffing = 6;
+				bit_idx++;
+			}
+		}
+	}
+
+	encoded[bit_idx >> 2] <<= 2;
+	encoded[bit_idx >> 2] |= FJ_USB_TX_ENCODED_SE0;
+	bit_idx++;
+	encoded[bit_idx >> 2] <<= 2;
+	encoded[bit_idx >> 2] |= FJ_USB_TX_ENCODED_COMP;
+	bit_idx++;
+	do {
+		encoded[bit_idx >> 2] <<= 2;
+		encoded[bit_idx >> 2] |= FJ_USB_TX_ENCODED_K;
+		bit_idx++;
+	} while (bit_idx & 0x03);
+
+	return bit_idx >> 2;
+}
+
+static int fj_usbhost_pio_write_tx_byte(struct fruitjam_usbhost *uh, u8 byte)
+{
+	u32 waited;
+
+	for (waited = 0; waited < FJ_USBHOST_FIFO_TIMEOUT_US; waited++) {
+		if (!(readl(uh->pio + FJ_PIO_FSTAT) &
+		      FJ_PIO_FSTAT_TXFULL(uh->sm_tx))) {
+			writeb(byte, uh->pio + FJ_PIO_TXF(uh->sm_tx));
+			return 0;
+		}
+		udelay(1);
+	}
+
+	return -ETIMEDOUT;
+}
+
+static int fj_usbhost_pio_tx_test(struct fruitjam_usbhost *uh)
+{
+	u8 packet[4] = { FJ_USB_SYNC, FJ_USB_PID_SOF, 0, 0 };
+	u8 encoded[FJ_USBHOST_TX_ENCODED_MAX];
+	u16 frame = uh->packets & 0x7ff;
+	u16 token = frame;
+	u8 encoded_len;
+	u32 waited;
+	int i;
+	int ret;
+
+	if (!fj_usbhost_pio_available(uh)) {
+		ret = -ENODEV;
+		goto out_no_pio;
+	}
+	if (!uh->pio_configured) {
+		ret = fj_usbhost_pio_configure_sms(uh);
+		if (ret)
+			goto out_no_pio;
+	}
+
+	packet[2] = token & 0xff;
+	packet[3] = ((u16)fj_usbhost_crc5_token(token) << 3) |
+		    ((token >> 8) & 0x7);
+	encoded_len = fj_usbhost_encode_tx(packet, sizeof(packet), encoded);
+	if (encoded_len > sizeof(encoded)) {
+		ret = -EOVERFLOW;
+		goto out;
+	}
+
+	writel(FJ_PIO_IRQ_TX_EOP, uh->pio + FJ_PIO_IRQ);
+	writel(FJ_PIO_FDEBUG_TXSTALL(uh->sm_tx), uh->pio + FJ_PIO_FDEBUG);
+	writel(FJ_PIO_TX_START_INSTR,
+	       fj_usbhost_pio_sm(uh, uh->sm_tx) + FJ_PIO_SM_INSTR);
+
+	for (i = 0; i < encoded_len; i++) {
+		ret = fj_usbhost_pio_write_tx_byte(uh, encoded[i]);
+		if (ret)
+			goto out;
+	}
+
+	ret = -ETIMEDOUT;
+	for (waited = 0; waited < FJ_USBHOST_TX_TIMEOUT_US; waited++) {
+		u32 irq = readl(uh->pio + FJ_PIO_IRQ);
+		u32 fdebug = readl(uh->pio + FJ_PIO_FDEBUG);
+
+		if (irq & FJ_PIO_IRQ_TX_EOP) {
+			writel(FJ_PIO_IRQ_TX_EOP, uh->pio + FJ_PIO_IRQ);
+			ret = 0;
+			break;
+		}
+		if (fdebug & FJ_PIO_FDEBUG_TXSTALL(uh->sm_tx)) {
+			ret = 0;
+			break;
+		}
+		udelay(1);
+	}
+
+out:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = ret ? 0 : encoded_len;
+	uh->last_pio_fstat = readl(uh->pio + FJ_PIO_FSTAT);
+	uh->last_pio_fdebug = readl(uh->pio + FJ_PIO_FDEBUG);
+	uh->last_pio_irq = readl(uh->pio + FJ_PIO_IRQ);
+	if (ret)
+		uh->tx_errors++;
+	else
+		uh->packets++;
+	return ret;
+
+out_no_pio:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->last_pio_fstat = 0;
+	uh->last_pio_fdebug = 0;
+	uh->last_pio_irq = 0;
+	uh->tx_errors++;
+	return ret;
+}
+
+static void fj_usbhost_pio_release(struct fruitjam_usbhost *uh)
+{
+	if (!uh->pio)
+		return;
+
+	fj_usbhost_pio_sm_disable(uh, uh->sm_tx);
+	fj_usbhost_pio_sm_disable(uh, uh->sm_rx);
+	fj_usbhost_pio_sm_disable(uh, uh->sm_eop);
+	uh->pio_configured = false;
+}
