+
+static void fj_usbhost_pio_sm_enable(struct fruitjam_usbhost *uh, u32 sm)
+{
+	u32 ctrl = readl(uh->pio + FJ_PIO_CTRL);
+
+	ctrl |= FJ_PIO_CTRL_SM_ENABLE(sm);
+	writel(ctrl, uh->pio + FJ_PIO_CTRL);
+}
+
+static void fj_usbhost_pio_sm_restart(struct fruitjam_usbhost *uh, u32 sm)
+{
+	u32 ctrl = readl(uh->pio + FJ_PIO_CTRL);
+
+	ctrl |= FJ_PIO_CTRL_SM_RESTART(sm);
+	ctrl |= FJ_PIO_CTRL_CLKDIV_RESTART(sm);
+	writel(ctrl, uh->pio + FJ_PIO_CTRL);
+}
+
+static void __iomem *fj_usbhost_pio_sm(struct fruitjam_usbhost *uh, u32 sm)
+{
+	return uh->pio + FJ_PIO_SM_BASE(sm);
+}
+
+static u32 fj_usbhost_clkdiv(struct fruitjam_usbhost *uh, u32 target_hz)
+{
+	u64 scaled = div64_u64((u64)uh->clk_sys_hz * 256 + target_hz / 2,
+			       target_hz);
+	u32 div_int = scaled >> 8;
+	u32 div_frac = scaled & 0xff;
+
+	if (!div_int)
+		div_int = 1;
+	if (div_int > 0xffff)
+		div_int = 0xffff;
+
+	return (div_int << 16) | (div_frac << 8);
 }
 
+static void fj_usbhost_pio_configure_gpio(struct fruitjam_usbhost *uh)
+{
+	u32 func = FJ_GPIO_FUNC_PIO0 + uh->pio_index;
+
+	fj_gpio_oe(uh, uh->dp_gpio, false);
+	fj_gpio_oe(uh, uh->dm_gpio, false);
+	writel(FJ_PADS_IE | FJ_PADS_PDE | FJ_PADS_DRIVE_12MA |
+	       FJ_PADS_SLEWFAST, uh->pads_bank0 + FJ_PADS_GPIO(uh->dp_gpio));
+	writel(FJ_PADS_IE | FJ_PADS_PDE | FJ_PADS_DRIVE_12MA |
+	       FJ_PADS_SLEWFAST, uh->pads_bank0 + FJ_PADS_GPIO(uh->dm_gpio));
+	fj_gpio_func(uh, uh->dp_gpio, func);
+	fj_gpio_func(uh, uh->dm_gpio, func);
+}
+
+static int fj_usbhost_pio_configure_sms(struct fruitjam_usbhost *uh)
+{
+	u32 pin_base = min(uh->dp_gpio, uh->dm_gpio);
+	void __iomem *tx_sm = fj_usbhost_pio_sm(uh, uh->sm_tx);
+	void __iomem *rx_sm = fj_usbhost_pio_sm(uh, uh->sm_rx);
+	void __iomem *eop_sm = fj_usbhost_pio_sm(uh, uh->sm_eop);
+
+	if (!uh->pio_ready)
+		return -ENODEV;
+	if (pin_base > 30 || uh->dp_gpio > 31 || uh->dm_gpio > 31)
+		return -EINVAL;
+
+	fj_usbhost_pio_sm_disable(uh, uh->sm_tx);
+	fj_usbhost_pio_sm_disable(uh, uh->sm_rx);
+	fj_usbhost_pio_sm_disable(uh, uh->sm_eop);
+	writel(FJ_PIO_IRQ_TX_EOP, uh->pio + FJ_PIO_IRQ);
+	writel(FJ_PIO_FDEBUG_TXSTALL(uh->sm_tx), uh->pio + FJ_PIO_FDEBUG);
+
+	fj_usbhost_pio_configure_gpio(uh);
+
+	writel(fj_usbhost_clkdiv(uh, 48000000u), tx_sm + FJ_PIO_SM_CLKDIV);
+	writel(FJ_PIO_EXECCTRL_WRAP_TOP(FJ_PIO_TX_WRAP) |
+	       FJ_PIO_EXECCTRL_WRAP_BOTTOM(FJ_PIO_TX_WRAP_TARGET),
+	       tx_sm + FJ_PIO_SM_EXECCTRL);
+	writel(FJ_PIO_SHIFTCTRL_FJOIN_TX |
+	       FJ_PIO_SHIFTCTRL_PULL_THRESH(8) |
+	       FJ_PIO_SHIFTCTRL_AUTOPULL, tx_sm + FJ_PIO_SM_SHIFTCTRL);
+	writel(FJ_PIO_PINCTRL_SIDESET_COUNT(2) |
+	       FJ_PIO_PINCTRL_SET_COUNT(2) |
+	       FJ_PIO_PINCTRL_OUT_COUNT(2) |
+	       FJ_PIO_PINCTRL_SIDESET_BASE(pin_base) |
+	       FJ_PIO_PINCTRL_SET_BASE(pin_base) |
+	       FJ_PIO_PINCTRL_OUT_BASE(pin_base), tx_sm + FJ_PIO_SM_PINCTRL);
+	writel(FJ_PIO_TX_INIT_INSTR, tx_sm + FJ_PIO_SM_INSTR);
+
+	writel(0x00010000u, rx_sm + FJ_PIO_SM_CLKDIV);
+	writel(FJ_PIO_EXECCTRL_JMP_PIN(uh->dp_gpio) |
+	       FJ_PIO_EXECCTRL_WRAP_TOP(FJ_PIO_RX_WRAP) |
+	       FJ_PIO_EXECCTRL_WRAP_BOTTOM(FJ_PIO_RX_WRAP_TARGET),
+	       rx_sm + FJ_PIO_SM_EXECCTRL);
+	writel(FJ_PIO_SHIFTCTRL_FJOIN_RX |
+	       FJ_PIO_SHIFTCTRL_PUSH_THRESH(8) |
+	       FJ_PIO_SHIFTCTRL_IN_SHIFTDIR |
+	       FJ_PIO_SHIFTCTRL_AUTOPUSH, rx_sm + FJ_PIO_SM_SHIFTCTRL);
+	writel(FJ_PIO_PINCTRL_IN_BASE(uh->dp_gpio), rx_sm + FJ_PIO_SM_PINCTRL);
+	writel(FJ_PIO_RX_INIT_INSTR, rx_sm + FJ_PIO_SM_INSTR);
+	writel(FJ_PIO_RX_OSR_ONES_INSTR, rx_sm + FJ_PIO_SM_INSTR);
+
+	writel(fj_usbhost_clkdiv(uh, 96000000u), eop_sm + FJ_PIO_SM_CLKDIV);
+	writel(FJ_PIO_EXECCTRL_JMP_PIN(uh->dm_gpio) |
+	       FJ_PIO_EXECCTRL_WRAP_TOP(FJ_PIO_EOP_WRAP) |
+	       FJ_PIO_EXECCTRL_WRAP_BOTTOM(FJ_PIO_EOP_WRAP_TARGET),
+	       eop_sm + FJ_PIO_SM_EXECCTRL);
+	writel(FJ_PIO_PINCTRL_IN_BASE(uh->dp_gpio), eop_sm + FJ_PIO_SM_PINCTRL);
+
+	fj_usbhost_pio_sm_restart(uh, uh->sm_tx);
+	fj_usbhost_pio_sm_restart(uh, uh->sm_rx);
+	fj_usbhost_pio_sm_restart(uh, uh->sm_eop);
+	fj_usbhost_pio_sm_enable(uh, uh->sm_tx);
+	fj_usbhost_pio_sm_enable(uh, uh->sm_eop);
+
+	uh->pio_configured = true;
+	return 0;
+}
+
 static int fj_usbhost_pio_init(struct fruitjam_usbhost *uh)
 {
 	u32 reset_bit = BIT(FJ_RESET_PIO0 + uh->pio_index);
@@ -238,9 +427,188 @@
