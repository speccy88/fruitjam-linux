+#define FJ_PIO_SM_CLKDIV		0x00
+#define FJ_PIO_SM_EXECCTRL		0x04
+#define FJ_PIO_SM_SHIFTCTRL		0x08
+#define FJ_PIO_SM_INSTR		0x10
