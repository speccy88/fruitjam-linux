 #define FJ_RESET_PIO0			11u
 
 #define FJ_PIO_CTRL_SM_ENABLE(sm)	BIT(sm)
+#define FJ_PIO_CTRL_SM_RESTART(sm)	BIT(4 + (sm))
+#define FJ_PIO_CTRL_CLKDIV_RESTART(sm)	BIT(8 + (sm))
+#define FJ_PIO_FSTAT_TXFULL(sm)	BIT(16 + (sm))
+#define FJ_PIO_FDEBUG_TXSTALL(sm)	BIT(24 + (sm))
+#define FJ_PIO_IRQ_TX_EOP		BIT(0)
+
+#define FJ_PIO_EXECCTRL_JMP_PIN(v)	(((v) & 0x1f) << 24)
+#define FJ_PIO_EXECCTRL_WRAP_TOP(v)	(((v) & 0x1f) << 12)
+#define FJ_PIO_EXECCTRL_WRAP_BOTTOM(v)	(((v) & 0x1f) << 7)
+#define FJ_PIO_SHIFTCTRL_FJOIN_TX	BIT(30)
+#define FJ_PIO_SHIFTCTRL_FJOIN_RX	BIT(31)
+#define FJ_PIO_SHIFTCTRL_PULL_THRESH(v)	(((v) & 0x1f) << 25)
+#define FJ_PIO_SHIFTCTRL_PUSH_THRESH(v)	(((v) & 0x1f) << 20)
+#define FJ_PIO_SHIFTCTRL_OUT_SHIFTDIR	BIT(19)
+#define FJ_PIO_SHIFTCTRL_IN_SHIFTDIR	BIT(18)
+#define FJ_PIO_SHIFTCTRL_AUTOPULL	BIT(17)
+#define FJ_PIO_SHIFTCTRL_AUTOPUSH	BIT(16)
+#define FJ_PIO_PINCTRL_SIDESET_COUNT(v)	(((v) & 0x7) << 29)
+#define FJ_PIO_PINCTRL_SET_COUNT(v)	(((v) & 0x7) << 26)
+#define FJ_PIO_PINCTRL_OUT_COUNT(v)	(((v) & 0x3f) << 20)
+#define FJ_PIO_PINCTRL_IN_BASE(v)	(((v) & 0x1f) << 15)
+#define FJ_PIO_PINCTRL_SIDESET_BASE(v)	(((v) & 0x1f) << 10)
+#define FJ_PIO_PINCTRL_SET_BASE(v)	(((v) & 0x1f) << 5)
+#define FJ_PIO_PINCTRL_OUT_BASE(v)	((v) & 0x1f)
+
