 #define FJ_PADS_GPIO(gpio)		(0x004 + ((gpio) * 4))
 #define FJ_GPIO_FUNC_SIO		5u
+#define FJ_GPIO_FUNC_PIO0		6u
 #define FJ_PADS_IE			BIT(6)
 #define FJ_PADS_PDE			BIT(2)
 #define FJ_PADS_DRIVE_4MA		BIT(4)
+#define FJ_PADS_DRIVE_12MA		(BIT(5) | BIT(4))
