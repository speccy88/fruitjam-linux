+
+static int fj_usbhost_pio_tx_packet(struct fruitjam_usbhost *uh,
+				    const u8 *packet, u8 packet_len,
+				    u8 *encoded_len)
+{
+	u8 encoded[FJ_USBHOST_TX_ENCODED_MAX];
+	u8 len;
+
+	len = fj_usbhost_encode_tx(packet, packet_len, encoded);
+	if (len > sizeof(encoded))
+		return -EOVERFLOW;
+	*encoded_len = len;
+	return fj_usbhost_pio_tx_encoded(uh, encoded, len);
+}
+
+static int fj_usbhost_pio_send_token(struct fruitjam_usbhost *uh,
+				     u8 pid, u8 addr, u8 ep,
+				     u8 *encoded_len)
+{
+	u16 token = ((u16)(ep & 0xf) << 7) | (addr & 0x7f);
+	u8 packet[4] = { FJ_USB_SYNC, pid, 0, 0 };
+
+	packet[2] = token & 0xff;
+	packet[3] = ((u16)fj_usbhost_crc5_token(token) << 3) |
+		    ((token >> 8) & 0x1f);
+	return fj_usbhost_pio_tx_packet(uh, packet, sizeof(packet), encoded_len);
+}
+
+static u16 fj_usbhost_crc16_data(const u8 *data, u8 len)
+{
+	u16 crc = 0xffff;
+	u8 i;
+
+	while (len--) {
+		crc ^= *data++;
+		for (i = 0; i < 8; i++)
+			crc = (crc & 1) ? (crc >> 1) ^ 0xa001 : crc >> 1;
+	}
+
+	return crc ^ 0xffff;
+}
+
+static int fj_usbhost_pio_send_data0(struct fruitjam_usbhost *uh,
+				     const u8 *payload, u8 payload_len,
+				     u8 *encoded_len)
+{
+	u8 packet[16];
+	u16 crc;
+
+	if (payload_len > 8)
+		return -EINVAL;
+
+	packet[0] = FJ_USB_SYNC;
+	packet[1] = FJ_USB_PID_DATA0;
+	memcpy(packet + 2, payload, payload_len);
+	crc = fj_usbhost_crc16_data(payload, payload_len);
+	packet[2 + payload_len] = crc & 0xff;
+	packet[3 + payload_len] = crc >> 8;
+
+	return fj_usbhost_pio_tx_packet(uh, packet, payload_len + 4,
+					encoded_len);
+}
+
+static int fj_usbhost_pio_send_ack(struct fruitjam_usbhost *uh)
+{
+	u8 packet[2] = { FJ_USB_SYNC, FJ_USB_PID_ACK };
+	u8 encoded_len = 0;
+
+	return fj_usbhost_pio_tx_packet(uh, packet, sizeof(packet), &encoded_len);
+}
+
+static int fj_usbhost_pio_tx_test(struct fruitjam_usbhost *uh)
+{
+	u8 packet[4] = { FJ_USB_SYNC, FJ_USB_PID_SOF, 0, 0 };
+	u16 frame = uh->packets & 0x7ff;
+	u16 token = frame;
+	u8 encoded_len = 0;
+	int ret;
+
+	if (!fj_usbhost_pio_available(uh)) {
+		ret = -ENODEV;
+		goto out_no_pio;
+	}
+	if (!uh->pio_configured) {
+		ret = fj_usbhost_pio_configure_sms(uh);
+		if (ret)
+			goto out_no_pio;
+	}
+
+	packet[2] = token & 0xff;
+	packet[3] = ((u16)fj_usbhost_crc5_token(token) << 3) |
+		    ((token >> 8) & 0x7);
+	ret = fj_usbhost_pio_tx_packet(uh, packet, sizeof(packet),
+				       &encoded_len);
+
 	uh->last_tx_result = ret;
 	uh->last_tx_len = ret ? 0 : encoded_len;
 	uh->last_pio_fstat = readl(uh->pio + FJ_PIO_FSTAT);
@@ -598,6 +757,167 @@
 	return ret;
 }
 
+static void fj_usbhost_pio_record_rx(struct fruitjam_usbhost *uh, int ret,
+				     u32 len)
+{
+	uh->last_rx_result = ret;
+	uh->last_rx_len = len;
+	uh->last_rx_pid = len >= 2 ? uh->last_rx_bytes[1] : 0;
+	uh->last_rx_irq = readl(uh->pio + FJ_PIO_IRQ);
+	uh->last_rx_flevel = readl(uh->pio + FJ_PIO_FLEVEL);
+	uh->last_pio_fstat = readl(uh->pio + FJ_PIO_FSTAT);
+	uh->last_pio_fdebug = readl(uh->pio + FJ_PIO_FDEBUG);
+	uh->last_pio_irq = uh->last_rx_irq;
+	uh->rx_attempts++;
+	if (ret)
+		uh->rx_errors++;
+}
+
+static int fj_usbhost_pio_receive_raw(struct fruitjam_usbhost *uh, bool ack_data)
+{
+	u32 waited;
+	u32 len = 0;
+	int ret = -ETIMEDOUT;
+
+	memset(uh->last_rx_bytes, 0, sizeof(uh->last_rx_bytes));
+	for (waited = 0; waited < FJ_USBHOST_RX_TIMEOUT_US; waited++) {
+		u32 irq;
+
+		while (!(readl(uh->pio + FJ_PIO_FSTAT) &
+			 FJ_PIO_FSTAT_RXEMPTY(uh->sm_rx))) {
+			if (len >= FJ_USBHOST_RX_BYTES_MAX) {
+				ret = -EOVERFLOW;
+				goto out;
+			}
+			uh->last_rx_bytes[len++] =
+				readl(uh->pio + FJ_PIO_RXF(uh->sm_rx)) >> 24;
+		}
+
+		irq = readl(uh->pio + FJ_PIO_IRQ);
+		if (irq & FJ_PIO_IRQ_RX_BS_ERR) {
+			ret = -EILSEQ;
+			break;
+		}
+		if (irq & FJ_PIO_IRQ_RX_EOP) {
+			ret = len ? 0 : -ENODATA;
+			break;
+		}
+		udelay(1);
+	}
+
+out:
+	if (!ret && ack_data && len >= 2 &&
+	    (uh->last_rx_bytes[1] == FJ_USB_PID_DATA0 ||
+	     uh->last_rx_bytes[1] == FJ_USB_PID_DATA1))
+		fj_usbhost_pio_send_ack(uh);
+	fj_usbhost_pio_sm_disable(uh, uh->sm_rx);
+	fj_usbhost_pio_record_rx(uh, ret, len);
+	return ret;
+}
+
+static int fj_usbhost_pio_require_configured(struct fruitjam_usbhost *uh)
+{
+	if (!fj_usbhost_pio_available(uh))
+		return -ENODEV;
+	if (uh->pio_configured)
+		return 0;
+	return fj_usbhost_pio_configure_sms(uh);
+}
+
+static void fj_usbhost_pio_record_tx(struct fruitjam_usbhost *uh, int ret,
+				     u8 encoded_len)
+{
+	uh->last_tx_result = ret;
+	uh->last_tx_len = ret ? 0 : encoded_len;
+	uh->last_pio_fstat = readl(uh->pio + FJ_PIO_FSTAT);
+	uh->last_pio_fdebug = readl(uh->pio + FJ_PIO_FDEBUG);
+	uh->last_pio_irq = readl(uh->pio + FJ_PIO_IRQ);
+	if (ret)
+		uh->tx_errors++;
+	else
+		uh->packets++;
+}
+
+static int fj_usbhost_pio_in_token(struct fruitjam_usbhost *uh)
+{
+	u8 encoded_len = 0;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	fj_usbhost_pio_prepare_receive(uh);
+	ret = fj_usbhost_pio_send_token(uh, FJ_USB_PID_IN, 0, 0, &encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+	fj_usbhost_pio_clear_rx_irq(uh);
+	return fj_usbhost_pio_receive_raw(uh, false);
+
+out_error:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->rx_errors++;
+	return ret;
+}
+
+static int fj_usbhost_pio_get_device8(struct fruitjam_usbhost *uh)
+{
+	static const u8 get_device8_setup[8] = {
+		0x80, 0x06, 0x00, 0x01, 0x00, 0x00, 0x08, 0x00,
+	};
+	u8 encoded_len = 0;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	fj_usbhost_pio_prepare_receive(uh);
+	ret = fj_usbhost_pio_send_token(uh, FJ_USB_PID_SETUP, 0, 0,
+					&encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+	ret = fj_usbhost_pio_send_data0(uh, get_device8_setup,
+					sizeof(get_device8_setup),
+					&encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+	fj_usbhost_pio_clear_rx_irq(uh);
+	ret = fj_usbhost_pio_receive_raw(uh, false);
+	if (ret)
+		return ret;
+	if (uh->last_rx_pid != FJ_USB_PID_ACK) {
+		fj_usbhost_pio_record_rx(uh, -EPROTO, uh->last_rx_len);
+		return -EPROTO;
+	}
+
+	fj_usbhost_pio_prepare_receive(uh);
+	ret = fj_usbhost_pio_send_token(uh, FJ_USB_PID_IN, 0, 0, &encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+	fj_usbhost_pio_clear_rx_irq(uh);
+	return fj_usbhost_pio_receive_raw(uh, true);
+
+out_error:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->rx_errors++;
+	return ret;
+}
+
 static void fj_usbhost_pio_release(struct fruitjam_usbhost *uh)
 {
 	if (!uh->pio)
@@ -638,10 +958,19 @@
