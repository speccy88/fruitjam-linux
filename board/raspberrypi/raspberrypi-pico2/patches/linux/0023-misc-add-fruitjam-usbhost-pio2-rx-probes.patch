+	}
+	rx_hex[i * 2] = '\0';
+
 	return scnprintf(buf, len,
 			 "power %u\n"
 			 "dp %u\n"
@@ -660,6 +989,14 @@
 			 "tx_errors %u\n"
 			 "last_tx_result %d\n"
 			 "last_tx_len %u\n"
+			 "rx_attempts %u\n"
+			 "rx_errors %u\n"
