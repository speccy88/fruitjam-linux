 static void fj_gpio_func(struct fruitjam_usbhost *uh, unsigned int gpio, u32 func)
 {
-	writel(func, uh->io_bank0 + FJ_IO_GPIO_CTRL(gpio));
+	void __iomem *ctrl = uh->io_bank0 + FJ_IO_GPIO_CTRL(gpio);
+	u32 value = readl(ctrl);
+
+	value &= ~(FJ_IO_GPIO_CTRL_FUNCSEL_MASK | FJ_IO_GPIO_CTRL_INOVER_MASK);
+	value |= func & FJ_IO_GPIO_CTRL_FUNCSEL_MASK;
+	writel(value, ctrl);
 }
 
+static void fj_gpio_inover(struct fruitjam_usbhost *uh, unsigned int gpio,
+			   bool invert)
+{
+	void __iomem *ctrl = uh->io_bank0 + FJ_IO_GPIO_CTRL(gpio);
+	u32 value = readl(ctrl);
+
+	value &= ~FJ_IO_GPIO_CTRL_INOVER_MASK;
+	value |= invert ? FJ_IO_GPIO_CTRL_INOVER_INVERT :
+			  FJ_IO_GPIO_CTRL_INOVER_NORMAL;
+	writel(value, ctrl);
+}
