 	       FJ_PADS_SLEWFAST, uh->pads_bank0 + FJ_PADS_GPIO(uh->dm_gpio));
 	fj_gpio_func(uh, uh->dp_gpio, func);
 	fj_gpio_func(uh, uh->dm_gpio, func);
+	fj_gpio_inover(uh, uh->dp_gpio, true);
+	fj_gpio_inover(uh, uh->dm_gpio, true);
 }
 
 static int fj_usbhost_pio_configure_sms(struct fruitjam_usbhost *uh)
@@ -518,36 +608,13 @@
 	return -ETIMEDOUT;
 }
 
