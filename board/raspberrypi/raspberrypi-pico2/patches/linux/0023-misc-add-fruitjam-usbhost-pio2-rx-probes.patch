+static void fj_usbhost_pio_sm_clear_fifos(struct fruitjam_usbhost *uh, u32 sm)
+{
+	void __iomem *shiftctrl = fj_usbhost_pio_sm(uh, sm) + FJ_PIO_SM_SHIFTCTRL;
+	u32 value = readl(shiftctrl);
+
+	writel(value ^ FJ_PIO_SHIFTCTRL_FJOIN_RX, shiftctrl);
+	writel(value, shiftctrl);
+}
+
+static void fj_usbhost_pio_prepare_receive(struct fruitjam_usbhost *uh)
+{
+	void __iomem *rx_sm = fj_usbhost_pio_sm(uh, uh->sm_rx);
+
+	fj_usbhost_pio_sm_disable(uh, uh->sm_rx);
+	fj_usbhost_pio_sm_clear_fifos(uh, uh->sm_rx);
+	fj_usbhost_pio_sm_restart(uh, uh->sm_rx);
+	writel(FJ_PIO_RX_INIT_INSTR, rx_sm + FJ_PIO_SM_INSTR);
+	writel(FJ_PIO_RX_OSR_ONES_INSTR, rx_sm + FJ_PIO_SM_INSTR);
+	fj_usbhost_pio_sm_enable(uh, uh->sm_rx);
+}
+
+static void fj_usbhost_pio_clear_rx_irq(struct fruitjam_usbhost *uh)
+{
+	u32 waited;
+
+	writel(FJ_PIO_IRQ_RX_ALL, uh->pio + FJ_PIO_IRQ);
+	for (waited = 0; waited < FJ_USBHOST_FIFO_TIMEOUT_US; waited++) {
+		if (!(readl(uh->pio + FJ_PIO_IRQ) & FJ_PIO_IRQ_RX_ALL))
+			break;
+		udelay(1);
+	}
 }
 
 static void fj_usbhost_pio_configure_gpio(struct fruitjam_usbhost *uh)
