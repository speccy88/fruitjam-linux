From 9bfe2c3f8b11a8270d1a4ec2d86d4f0a62a2f928 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Tue, 16 Jun 2026 16:10:00 +0000
Subject: [PATCH] misc: add Fruit Jam usbhost self-RX probe

The first hardware probes can transmit USB packets, but RX still times
out waiting for a device response. Add a diagnostic command that arms RX,
sends a harmless SOF packet, and then reads RX without clearing RX IRQs
after TX.

This separates "RX cannot see the pins/program at all" from "the attached
device is not answering our host traffic".
---
 drivers/misc/fruitjam_usbhost.c | 47 ++++++++++++++++++++++++++++++++
 1 file changed, 47 insertions(+)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
index 222222222222..333333333333 100644
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -1053,6 +1053,51 @@
 		uh->packets++;
 }
 
+static int fj_usbhost_pio_self_rx(struct fruitjam_usbhost *uh)
+{
+	u8 packet[4] = { FJ_USB_SYNC, FJ_USB_PID_SOF, 0, 0 };
+	u16 frame = uh->packets & 0x7ff;
+	u16 token = frame;
+	u8 encoded_len = 0;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	packet[2] = token & 0xff;
+	packet[3] = ((u16)fj_usbhost_crc5_token(token) << 3) |
+		    ((token >> 8) & 0x7);
+
+	fj_usbhost_pio_prepare_receive(uh);
+	ret = fj_usbhost_pio_tx_packet(uh, packet, sizeof(packet),
+				       &encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+
+	/*
+	 * Do not clear RX IRQs here.  A working loopback-visible RX path should
+	 * decode the packet we just drove onto D+/D-, so preserve those flags.
+	 */
+	return fj_usbhost_pio_receive_raw(uh, false);
+
+out_error:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->last_rx_irq = uh->pio ? readl(uh->pio + FJ_PIO_IRQ) : 0;
+	uh->last_rx_flevel = uh->pio ? readl(uh->pio + FJ_PIO_FLEVEL) : 0;
+	uh->last_pio_fstat = uh->pio ? readl(uh->pio + FJ_PIO_FSTAT) : 0;
+	uh->last_pio_fdebug = uh->pio ? readl(uh->pio + FJ_PIO_FDEBUG) : 0;
+	uh->last_pio_irq = uh->last_rx_irq;
+	uh->rx_errors++;
+	return ret;
+}
+
 static int fj_usbhost_pio_in_token(struct fruitjam_usbhost *uh)
 {
 	u8 encoded_len = 0;
@@ -1324,6 +1369,8 @@
 		ret = fj_usbhost_pio_configure_sms(uh);
 	} else if (!strcmp(cmd, "tx-test")) {
 		ret = fj_usbhost_pio_tx_test(uh);
+	} else if (!strcmp(cmd, "self-rx")) {
+		ret = fj_usbhost_pio_self_rx(uh);
 	} else if (!strcmp(cmd, "in-token")) {
 		ret = fj_usbhost_pio_in_token(uh);
 	} else if (!strcmp(cmd, "get-device-8")) {
