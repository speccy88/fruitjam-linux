From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Tue, 16 Jun 2026 13:31:00 -0400
Subject: [PATCH] misc: expose Fruit Jam usbhost PIO debug state

The bridge is still below a complete HID host stack, so keep the low-level
debug state visible through /dev/fruitjam-usbhost.  This avoids adding a
target-side devmem utility while still exposing the PIO SM PCs, pinctrls,
execctrls, and DP/DM IO control registers needed to debug no-response USB
transactions on hardware.
---
 drivers/misc/fruitjam_usbhost.c | 35 +++++++++++++++++++++++++++++++++++
 1 file changed, 35 insertions(+)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
index 888888888888..999999999999 100644
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -1269,6 +1269,27 @@
 	const char *state = fj_usbhost_state(power, dp, dm);
 	char rx_hex[FJ_USBHOST_RX_BYTES_MAX * 2 + 1];
 	static const char hex[] = "0123456789abcdef";
+	void __iomem *tx_sm = uh->pio ? fj_usbhost_pio_sm(uh, uh->sm_tx) : NULL;
+	void __iomem *rx_sm = uh->pio ? fj_usbhost_pio_sm(uh, uh->sm_rx) : NULL;
+	void __iomem *eop_sm = uh->pio ? fj_usbhost_pio_sm(uh, uh->sm_eop) : NULL;
+	u32 pio_ctrl = uh->pio ? readl(uh->pio + FJ_PIO_CTRL) : 0;
+	u32 tx_addr = tx_sm ? readl(tx_sm + FJ_PIO_SM_ADDR) & 0x1f : 0;
+	u32 rx_addr = rx_sm ? readl(rx_sm + FJ_PIO_SM_ADDR) & 0x1f : 0;
+	u32 eop_addr = eop_sm ? readl(eop_sm + FJ_PIO_SM_ADDR) & 0x1f : 0;
+	u32 tx_execctrl = tx_sm ? readl(tx_sm + FJ_PIO_SM_EXECCTRL) : 0;
+	u32 rx_execctrl = rx_sm ? readl(rx_sm + FJ_PIO_SM_EXECCTRL) : 0;
+	u32 eop_execctrl = eop_sm ? readl(eop_sm + FJ_PIO_SM_EXECCTRL) : 0;
+	u32 tx_pinctrl = tx_sm ? readl(tx_sm + FJ_PIO_SM_PINCTRL) : 0;
+	u32 rx_pinctrl = rx_sm ? readl(rx_sm + FJ_PIO_SM_PINCTRL) : 0;
+	u32 eop_pinctrl = eop_sm ? readl(eop_sm + FJ_PIO_SM_PINCTRL) : 0;
+	u32 dp_ctrl = (uh->io_bank0 && uh->dp_gpio <= 31) ?
+		      readl(uh->io_bank0 + FJ_IO_GPIO_CTRL(uh->dp_gpio)) : 0;
+	u32 dm_ctrl = (uh->io_bank0 && uh->dm_gpio <= 31) ?
+		      readl(uh->io_bank0 + FJ_IO_GPIO_CTRL(uh->dm_gpio)) : 0;
+	u32 dp_pad = (uh->pads_bank0 && uh->dp_gpio <= 31) ?
+		     readl(uh->pads_bank0 + FJ_PADS_GPIO(uh->dp_gpio)) : 0;
+	u32 dm_pad = (uh->pads_bank0 && uh->dm_gpio <= 31) ?
+		     readl(uh->pads_bank0 + FJ_PADS_GPIO(uh->dm_gpio)) : 0;
 	u32 i;
 
 	for (i = 0; i < uh->last_rx_len && i < FJ_USBHOST_RX_BYTES_MAX; i++) {
@@ -1311,6 +1332,20 @@
 			 "pio_fstat 0x%08x\n"
 			 "pio_fdebug 0x%08x\n"
 			 "pio_irq 0x%08x\n"
+			 "pio_ctrl 0x%08x\n"
+			 "tx_addr %u\n"
+			 "rx_addr %u\n"
+			 "eop_addr %u\n"
+			 "tx_execctrl 0x%08x\n"
+			 "rx_execctrl 0x%08x\n"
+			 "eop_execctrl 0x%08x\n"
+			 "tx_pinctrl 0x%08x\n"
+			 "rx_pinctrl 0x%08x\n"
+			 "eop_pinctrl 0x%08x\n"
+			 "dp_ctrl 0x%08x\n"
+			 "dm_ctrl 0x%08x\n"
+			 "dp_pad 0x%08x\n"
+			 "dm_pad 0x%08x\n"
 			 "first_milestone boot-protocol-keyboard\n"
 			 "reports 0\n"
 			 "last_reset_ms %u\n",
-- 
2.39.5
