From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Tue, 16 Jun 2026 21:05:00 -0400
Subject: [PATCH] misc: add Fruit Jam usbhost SETUP DATA self-RX probe

The gated GET_DESCRIPTOR probe can now wait until TX finishes before enabling
RX, but the device still ends the response window without any decoded bytes.
Add a focused loopback diagnostic for the exact DATA0 SETUP packet used by
GET_DESCRIPTOR so the bring-up can distinguish an encoded SETUP payload problem
from a downstream device-turnaround or handshake problem.
---
 drivers/misc/fruitjam_usbhost.c | 45 +++++++++++++++++++++++++++++++++
 1 file changed, 45 insertions(+)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
index ffffffffffff..111111111111 100644
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -1259,6 +1259,49 @@ static int fj_usbhost_pio_in_token(struct fruitjam_usbhost *uh)
 	return ret;
 }
 
+static int fj_usbhost_pio_setup_data_self_rx(struct fruitjam_usbhost *uh)
+{
+	static const u8 get_device8_setup[8] = {
+		0x80, 0x06, 0x00, 0x01, 0x00, 0x00, 0x08, 0x00,
+	};
+	u8 encoded_len = 0;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	fj_usbhost_pio_prepare_receive(uh);
+	fj_usbhost_pio_clear_rx_irq(uh);
+	ret = fj_usbhost_pio_send_data0(uh, get_device8_setup,
+					sizeof(get_device8_setup),
+					&encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+
+	/*
+	 * Keep RX armed while TX drives the packet.  A healthy local RX path
+	 * should decode the same DATA0 bytes sent during GET_DESCRIPTOR.
+	 */
+	return fj_usbhost_pio_receive_raw(uh, false);
+
+out_error:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->last_rx_irq = uh->pio ? readl(uh->pio + FJ_PIO_IRQ) : 0;
+	uh->last_rx_flevel = uh->pio ? readl(uh->pio + FJ_PIO_FLEVEL) : 0;
+	uh->last_pio_fstat = uh->pio ? readl(uh->pio + FJ_PIO_FSTAT) : 0;
+	uh->last_pio_fdebug = uh->pio ? readl(uh->pio + FJ_PIO_FDEBUG) : 0;
+	uh->last_pio_irq = uh->last_rx_irq;
+	uh->rx_errors++;
+	return ret;
+}
+
 static int fj_usbhost_pio_get_device8(struct fruitjam_usbhost *uh)
 {
 	static const u8 get_device8_setup[8] = {
@@ -1626,6 +1669,8 @@ static ssize_t fj_usbhost_write(struct file *file, const char __user *buf,
 		ret = fj_usbhost_pio_self_rx(uh);
 	} else if (!strcmp(cmd, "in-token")) {
 		ret = fj_usbhost_pio_in_token(uh);
+	} else if (!strcmp(cmd, "setup-data-self-rx")) {
+		ret = fj_usbhost_pio_setup_data_self_rx(uh);
 	} else if (!strcmp(cmd, "get-device-8")) {
 		ret = fj_usbhost_pio_get_device8(uh);
 	} else if (!strcmp(cmd, "in-token-gated")) {
-- 
