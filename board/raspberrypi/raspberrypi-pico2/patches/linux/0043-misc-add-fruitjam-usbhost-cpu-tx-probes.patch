From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Tue, 16 Jun 2026 22:30:00 -0400
Subject: [PATCH] misc: add Fruit Jam usbhost CPU TX probes

The DMA-fed SETUP DATA self-RX probe still truncates long packets on hardware.
Add explicit CPU-fed token/DATA0 paths and expose diagnostic commands that can
compare CPU TX against DMA TX without changing the normal probe path.
---
 drivers/misc/fruitjam_usbhost.c | 152 +++++++++++++++++++++++++++++++
 1 file changed, 152 insertions(+)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
index 111111111111..222222222222 100644
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -984,6 +984,22 @@ static int fj_usbhost_pio_tx_packet(struct fruitjam_usbhost *uh,
 		return -EOVERFLOW;
 	*encoded_len = len;
 	return fj_usbhost_pio_tx_encoded(uh, encoded, len);
+}
+
+static int fj_usbhost_pio_tx_packet_cpu(struct fruitjam_usbhost *uh,
+					const u8 *packet, u8 packet_len,
+					u8 *encoded_len)
+{
+	u8 encoded[FJ_USBHOST_TX_ENCODED_MAX];
+	u8 len;
+
+	len = fj_usbhost_encode_tx(packet, packet_len, encoded);
+	if (len > sizeof(encoded))
+		return -EOVERFLOW;
+	*encoded_len = len;
+	uh->last_dma_result = -EOPNOTSUPP;
+	uh->last_dma_ctrl = 0;
+	return fj_usbhost_pio_tx_encoded_cpu(uh, encoded, len);
 }
 
 static int fj_usbhost_pio_send_token(struct fruitjam_usbhost *uh,
@@ -999,6 +1015,20 @@ static int fj_usbhost_pio_send_token(struct fruitjam_usbhost *uh,
 	return fj_usbhost_pio_tx_packet(uh, packet, sizeof(packet), encoded_len);
 }
 
+static int fj_usbhost_pio_send_token_cpu(struct fruitjam_usbhost *uh,
+					 u8 pid, u8 addr, u8 ep,
+					 u8 *encoded_len)
+{
+	u16 token = ((u16)(ep & 0xf) << 7) | (addr & 0x7f);
+	u8 packet[4] = { FJ_USB_SYNC, pid, 0, 0 };
+
+	packet[2] = token & 0xff;
+	packet[3] = ((u16)fj_usbhost_crc5_token(token) << 3) |
+		    ((token >> 8) & 0x1f);
+	return fj_usbhost_pio_tx_packet_cpu(uh, packet, sizeof(packet),
+					    encoded_len);
+}
+
 static u16 fj_usbhost_crc16_data(const u8 *data, u8 len)
 {
 	u16 crc = 0xffff;
@@ -1034,6 +1064,27 @@ static int fj_usbhost_pio_send_data0(struct fruitjam_usbhost *uh,
 					encoded_len);
 }
 
+static int fj_usbhost_pio_send_data0_cpu(struct fruitjam_usbhost *uh,
+					 const u8 *payload, u8 payload_len,
+					 u8 *encoded_len)
+{
+	u8 packet[16];
+	u16 crc;
+
+	if (payload_len > 8)
+		return -EINVAL;
+
+	packet[0] = FJ_USB_SYNC;
+	packet[1] = FJ_USB_PID_DATA0;
+	memcpy(packet + 2, payload, payload_len);
+	crc = fj_usbhost_crc16_data(payload, payload_len);
+	packet[2 + payload_len] = crc & 0xff;
+	packet[3 + payload_len] = crc >> 8;
+
+	return fj_usbhost_pio_tx_packet_cpu(uh, packet, payload_len + 4,
+					    encoded_len);
+}
+
 static int fj_usbhost_pio_send_ack(struct fruitjam_usbhost *uh)
 {
 	u8 packet[2] = { FJ_USB_SYNC, FJ_USB_PID_ACK };
@@ -1286,6 +1337,48 @@ static int fj_usbhost_pio_setup_data_self_rx(struct fruitjam_usbhost *uh)
 	/*
 	 * Keep RX armed while TX drives the packet.  A healthy local RX path
 	 * should decode the same DATA0 bytes sent during GET_DESCRIPTOR.
+	 */
+	return fj_usbhost_pio_receive_raw(uh, false);
+
+out_error:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->last_rx_irq = uh->pio ? readl(uh->pio + FJ_PIO_IRQ) : 0;
+	uh->last_rx_flevel = uh->pio ? readl(uh->pio + FJ_PIO_FLEVEL) : 0;
+	uh->last_pio_fstat = uh->pio ? readl(uh->pio + FJ_PIO_FSTAT) : 0;
+	uh->last_pio_fdebug = uh->pio ? readl(uh->pio + FJ_PIO_FDEBUG) : 0;
+	uh->last_pio_irq = uh->last_rx_irq;
+	uh->rx_errors++;
+	return ret;
+}
+
+static int fj_usbhost_pio_setup_data_self_rx_cpu(struct fruitjam_usbhost *uh)
+{
+	static const u8 get_device8_setup[8] = {
+		0x80, 0x06, 0x00, 0x01, 0x00, 0x00, 0x08, 0x00,
+	};
+	u8 encoded_len = 0;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	fj_usbhost_pio_prepare_receive(uh);
+	fj_usbhost_pio_clear_rx_irq(uh);
+	ret = fj_usbhost_pio_send_data0_cpu(uh, get_device8_setup,
+					    sizeof(get_device8_setup),
+					    &encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+
+	/*
+	 * Force CPU-fed TX here to split DMA behavior from PIO/RX timing.
 	 */
 	return fj_usbhost_pio_receive_raw(uh, false);
 
@@ -1344,6 +1437,59 @@ static int fj_usbhost_pio_get_device8(struct fruitjam_usbhost *uh)
 	if (ret)
 		return ret;
 	fj_usbhost_pio_clear_rx_irq(uh);
+	return fj_usbhost_pio_receive_raw(uh, true);
+
+out_error:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->rx_errors++;
+	return ret;
+}
+
+static int fj_usbhost_pio_get_device8_gated_cpu(struct fruitjam_usbhost *uh)
+{
+	static const u8 get_device8_setup[8] = {
+		0x80, 0x06, 0x00, 0x01, 0x00, 0x00, 0x08, 0x00,
+	};
+	u8 encoded_len = 0;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	fj_usbhost_pio_disable_receive(uh);
+	ret = fj_usbhost_pio_send_token_cpu(uh, FJ_USB_PID_SETUP, 0, 0,
+					    &encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+
+	fj_usbhost_pio_prepare_receive_after_tx(uh);
+	ret = fj_usbhost_pio_send_data0_cpu(uh, get_device8_setup,
+					    sizeof(get_device8_setup),
+					    &encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+	ret = fj_usbhost_pio_receive_raw(uh, false);
+	if (ret)
+		return ret;
+	if (uh->last_rx_pid != FJ_USB_PID_ACK) {
+		fj_usbhost_pio_record_rx(uh, -EPROTO, uh->last_rx_len);
+		return -EPROTO;
+	}
+
+	fj_usbhost_pio_prepare_receive_after_tx(uh);
+	ret = fj_usbhost_pio_send_token_cpu(uh, FJ_USB_PID_IN, 0, 0,
+					    &encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
 	return fj_usbhost_pio_receive_raw(uh, true);
 
 out_error:
@@ -1681,12 +1827,16 @@ static ssize_t fj_usbhost_write(struct file *file, const char __user *buf,
 		ret = fj_usbhost_pio_in_token(uh);
 	} else if (!strcmp(cmd, "setup-data-self-rx")) {
 		ret = fj_usbhost_pio_setup_data_self_rx(uh);
+	} else if (!strcmp(cmd, "setup-data-self-rx-cpu")) {
+		ret = fj_usbhost_pio_setup_data_self_rx_cpu(uh);
 	} else if (!strcmp(cmd, "get-device-8")) {
 		ret = fj_usbhost_pio_get_device8(uh);
 	} else if (!strcmp(cmd, "in-token-gated")) {
 		ret = fj_usbhost_pio_in_token_gated(uh);
 	} else if (!strcmp(cmd, "get-device-8-gated")) {
 		ret = fj_usbhost_pio_get_device8_gated(uh);
+	} else if (!strcmp(cmd, "get-device-8-gated-cpu")) {
+		ret = fj_usbhost_pio_get_device8_gated_cpu(uh);
 	} else if (!strcmp(cmd, "status")) {
 		/* read-only command for shell scripts that write then read */
 	} else {
-- 
2.39.5
