From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Tue, 16 Jun 2026 23:40:00 -0400
Subject: [PATCH] misc: add Fruit Jam usbhost DATA0 length sweep

The short SOF self-RX probe decodes cleanly, while the GET_DESCRIPTOR SETUP
DATA0 self-RX probe decodes only the first nine bytes of a twelve-byte packet.
Add a compact payload-length sweep so hardware tests can identify whether the
PIO receive path fails at a packet length boundary or at the specific trailing
byte pattern in the SETUP packet.
---
 drivers/misc/fruitjam_usbhost.c | 61 ++++++++++++++++++++++++++++++++-
 1 file changed, 60 insertions(+), 1 deletion(-)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
index 111111111111..222222222222 100644
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -38,6 +38,7 @@
 #define FJ_USBHOST_TX_ENCODED_MAX	96u
 #define FJ_USBHOST_RX_BYTES_MAX		32u
 #define FJ_USBHOST_TX_DMA_CHANNEL_DEFAULT 2u
+#define FJ_USBHOST_PROBE_SUMMARY_MAX	512u
 #define FJ_USBHOST_DMA_TIMEOUT_US	2000u
 
 #define FJ_PIO_SM_ADDR			0x0c
@@ -243,6 +245,7 @@ struct fruitjam_usbhost {
 	u8 tx_dma_buf[FJ_USBHOST_TX_ENCODED_MAX];
 	bool pio_ready;
 	bool pio_configured;
+	char last_probe_summary[FJ_USBHOST_PROBE_SUMMARY_MAX];
 };
 
 /*
@@ -1408,6 +1411,65 @@ out_error:
 	return ret;
 }
 
+static int fj_usbhost_pio_data_len_sweep(struct fruitjam_usbhost *uh)
+{
+	static const u8 get_device8_setup[8] = {
+		0x80, 0x06, 0x00, 0x01, 0x00, 0x00, 0x08, 0x00,
+	};
+	u32 off;
+	u8 payload_len;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	off = scnprintf(uh->last_probe_summary,
+			sizeof(uh->last_probe_summary), "data-len-sweep");
+	for (payload_len = 0; payload_len <= sizeof(get_device8_setup);
+	     payload_len++) {
+		u8 encoded_len = 0;
+
+		fj_usbhost_pio_prepare_receive(uh);
+		fj_usbhost_pio_clear_rx_irq(uh);
+		ret = fj_usbhost_pio_send_data0(uh, get_device8_setup,
+						payload_len, &encoded_len);
+		fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+		if (!ret)
+			ret = fj_usbhost_pio_receive_raw(uh, false);
+		if (off < sizeof(uh->last_probe_summary))
+			off += scnprintf(uh->last_probe_summary + off,
+					 sizeof(uh->last_probe_summary) - off,
+					 " %u:%u/%u/%d/0x%02x",
+					 payload_len, uh->last_rx_len,
+					 payload_len + 4, ret,
+					 uh->last_rx_pid);
+	}
+
+	/*
+	 * This is diagnostic: keep the command successful when packets were
+	 * transmitted and measured, even if the summary records a failed length.
+	 */
+	return 0;
+
+out_error:
+	scnprintf(uh->last_probe_summary, sizeof(uh->last_probe_summary),
+		  "data-len-sweep setup-error %d", ret);
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->last_rx_irq = uh->pio ? readl(uh->pio + FJ_PIO_IRQ) : 0;
+	uh->last_rx_flevel = uh->pio ? readl(uh->pio + FJ_PIO_FLEVEL) : 0;
+	uh->last_pio_fstat = uh->pio ? readl(uh->pio + FJ_PIO_FSTAT) : 0;
+	uh->last_pio_fdebug = uh->pio ? readl(uh->pio + FJ_PIO_FDEBUG) : 0;
+	uh->last_pio_irq = uh->last_rx_irq;
+	uh->rx_errors++;
+	return ret;
+}
+
 static int fj_usbhost_pio_setup_data_self_rx_cpu(struct fruitjam_usbhost *uh)
 {
 	static const u8 get_device8_setup[8] = {
@@ -1655,6 +1717,7 @@ static int fj_usbhost_format_status(struct fruitjam_usbhost *uh,
 	u32 eop_pinctrl = eop_sm ? readl(eop_sm + FJ_PIO_SM_PINCTRL) : 0;
 	u32 dp_ctrl = (uh->io_bank0 && uh->dp_gpio <= 31) ?
 		      readl(uh->io_bank0 + FJ_IO_GPIO_CTRL(uh->dp_gpio)) : 0;
+	const char *probe_summary = *uh->last_probe_summary ? uh->last_probe_summary : "none";
 	u32 dm_ctrl = (uh->io_bank0 && uh->dm_gpio <= 31) ?
 		      readl(uh->io_bank0 + FJ_IO_GPIO_CTRL(uh->dm_gpio)) : 0;
 	u32 dp_pad = (uh->pads_bank0 && uh->dp_gpio <= 31) ?
@@ -1709,6 +1772,7 @@ static int fj_usbhost_format_status(struct fruitjam_usbhost *uh,
 			 "pio_fdebug 0x%08x\n"
 			 "pio_irq 0x%08x\n"
 			 "pio_ctrl 0x%08x\n"
+			 "probe_summary %s\n"
 			 "tx_addr %u\n"
 			 "rx_addr %u\n"
 			 "eop_addr %u\n"
@@ -1736,7 +1800,7 @@ static int fj_usbhost_format_status(struct fruitjam_usbhost *uh,
 			 uh->last_rx_flevel, rx_hex,
 			 uh->last_pio_fstat, uh->last_pio_fdebug,
 			 uh->last_pio_irq, pio_ctrl,
-			 tx_addr, rx_addr, eop_addr,
+			 probe_summary, tx_addr, rx_addr, eop_addr,
 			 tx_execctrl, rx_execctrl, eop_execctrl,
 			 tx_pinctrl, rx_pinctrl, eop_pinctrl,
 			 dp_ctrl, dm_ctrl, dp_pad, dm_pad,
@@ -1812,6 +1876,8 @@ static ssize_t fj_usbhost_write(struct file *file, const char __user *buf,
 		ret = fj_usbhost_pio_setup_data_self_rx_noeop(uh);
 	} else if (!strcmp(cmd, "setup-data-self-rx-cpu")) {
 		ret = fj_usbhost_pio_setup_data_self_rx_cpu(uh);
+	} else if (!strcmp(cmd, "data-len-sweep")) {
+		ret = fj_usbhost_pio_data_len_sweep(uh);
 	} else if (!strcmp(cmd, "get-device-8")) {
 		ret = fj_usbhost_pio_get_device8(uh);
 	} else if (!strcmp(cmd, "in-token-gated")) {
-- 
