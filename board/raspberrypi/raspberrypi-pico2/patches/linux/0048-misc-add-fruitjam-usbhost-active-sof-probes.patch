From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Tue, 16 Jun 2026 17:25:00 -0400
Subject: [PATCH] misc: add Fruit Jam usbhost active SOF probes

The one-shot GET_DESCRIPTOR probes can be run long after reset, when a
full-speed device has seen no SOFs for far longer than the suspend threshold.
Add tiny kernel-side SOF burst helpers plus combined reset/SOF/GET_DESCRIPTOR
probes so reset recovery, frame keepalives, and the control transfer happen
without shell scheduling gaps.  Also add a SETUP-token self-RX diagnostic to
separate token encoding from device-response timing.
---
 drivers/misc/fruitjam_usbhost.c | 101 ++++++++++++++++++++++++++++++++
 1 file changed, 101 insertions(+)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
index 111111111111..222222222222 100644
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -53,6 +53,8 @@
 #define FJ_USBHOST_TX_DMA_CHANNEL_DEFAULT 2u
 #define FJ_USBHOST_PROBE_SUMMARY_MAX	512u
 #define FJ_USBHOST_DMA_TIMEOUT_US	2000u
+#define FJ_USBHOST_SOF_BURST_FRAMES	20u
+#define FJ_USBHOST_ACTIVE_RESET_MS	50u
 
 #define FJ_PIO_SM_ADDR			0x0c
 #define FJ_RESET_DMA			2u
@@ -1372,6 +1410,41 @@ out_error:
 	return ret;
 }
 
+static int fj_usbhost_pio_setup_token_self_rx(struct fruitjam_usbhost *uh)
+{
+	u8 encoded_len = 0;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	fj_usbhost_pio_prepare_receive(uh);
+	fj_usbhost_pio_clear_rx_irq(uh);
+	ret = fj_usbhost_pio_send_token(uh, FJ_USB_PID_SETUP, 0, 0,
+					&encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+
+	return fj_usbhost_pio_receive_raw(uh, false);
+
+out_error:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->last_rx_irq = uh->pio ? readl(uh->pio + FJ_PIO_IRQ) : 0;
+	uh->last_rx_flevel = uh->pio ? readl(uh->pio + FJ_PIO_FLEVEL) : 0;
+	uh->last_pio_fstat = uh->pio ? readl(uh->pio + FJ_PIO_FSTAT) : 0;
+	uh->last_pio_fdebug = uh->pio ? readl(uh->pio + FJ_PIO_FDEBUG) : 0;
+	uh->last_pio_irq = uh->last_rx_irq;
+	uh->rx_errors++;
+	return ret;
+}
+
 static int fj_usbhost_pio_setup_data_self_rx(struct fruitjam_usbhost *uh)
 {
 	static const u8 get_device8_setup[8] = {
@@ -1741,6 +1776,74 @@ out_error:
 	return ret;
 }
 
+static int fj_usbhost_pio_send_sof(struct fruitjam_usbhost *uh, u16 frame,
+				   u8 *encoded_len)
+{
+	u16 token = frame & 0x7ff;
+	u8 packet[4] = { FJ_USB_SYNC, FJ_USB_PID_SOF, 0, 0 };
+
+	packet[2] = token & 0xff;
+	packet[3] = ((u16)fj_usbhost_crc5_token(token) << 3) |
+		    ((token >> 8) & 0x7);
+
+	return fj_usbhost_pio_tx_packet(uh, packet, sizeof(packet),
+					encoded_len);
+}
+
+static int fj_usbhost_pio_sof_burst(struct fruitjam_usbhost *uh, u32 frames)
+{
+	u32 frame;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		return ret;
+
+	for (frame = 0; frame < frames; frame++) {
+		u8 encoded_len = 0;
+
+		ret = fj_usbhost_pio_send_sof(uh, uh->packets & 0x7ff,
+					      &encoded_len);
+		fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+		if (ret)
+			return ret;
+		usleep_range(1000, 1100);
+	}
+	return 0;
+}
+
+static int fj_usbhost_pio_reset_active(struct fruitjam_usbhost *uh)
+{
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		return ret;
+
+	fj_gpio_output(uh, uh->power_gpio, true);
+	msleep(FJ_USBHOST_POST_RESET_MS);
+	fj_usbhost_bus_reset_override(uh, true);
+	msleep(FJ_USBHOST_ACTIVE_RESET_MS);
+	fj_usbhost_bus_reset_override(uh, false);
+	udelay(100);
+	uh->last_reset_ms = FJ_USBHOST_ACTIVE_RESET_MS;
+	return fj_usbhost_pio_sof_burst(uh, FJ_USBHOST_SOF_BURST_FRAMES);
+}
+
+static int fj_usbhost_pio_get_device8_active(struct fruitjam_usbhost *uh)
+{
+	int ret = fj_usbhost_pio_reset_active(uh);
+
+	return ret ? ret : fj_usbhost_pio_get_device8(uh);
+}
+
+static int fj_usbhost_pio_get_device8_active_gated(struct fruitjam_usbhost *uh)
+{
+	int ret = fj_usbhost_pio_reset_active(uh);
+
+	return ret ? ret : fj_usbhost_pio_get_device8_gated(uh);
+}
+
 static void fj_usbhost_pio_release(struct fruitjam_usbhost *uh)
 {
 	if (!uh->pio)
@@ -1994,8 +2087,12 @@ static ssize_t fj_usbhost_write(struct file *file, const char __user *buf,
 		ret = fj_usbhost_pio_tx_test(uh);
 	} else if (!strcmp(cmd, "self-rx")) {
 		ret = fj_usbhost_pio_self_rx(uh);
+	} else if (!strcmp(cmd, "sof-burst")) {
+		ret = fj_usbhost_pio_sof_burst(uh, FJ_USBHOST_SOF_BURST_FRAMES);
 	} else if (!strcmp(cmd, "in-token")) {
 		ret = fj_usbhost_pio_in_token(uh);
+	} else if (!strcmp(cmd, "setup-token-self-rx")) {
+		ret = fj_usbhost_pio_setup_token_self_rx(uh);
 	} else if (!strcmp(cmd, "setup-data-self-rx")) {
 		ret = fj_usbhost_pio_setup_data_self_rx(uh);
 	} else if (!strcmp(cmd, "setup-data-self-rx-noeop")) {
@@ -2010,6 +2107,10 @@ static ssize_t fj_usbhost_write(struct file *file, const char __user *buf,
 		ret = fj_usbhost_pio_get_device8_gated(uh);
 	} else if (!strcmp(cmd, "get-device-8-gated-cpu")) {
 		ret = fj_usbhost_pio_get_device8_gated_cpu(uh);
+	} else if (!strcmp(cmd, "reset-get-device-8")) {
+		ret = fj_usbhost_pio_get_device8_active(uh);
+	} else if (!strcmp(cmd, "reset-get-device-8-gated")) {
+		ret = fj_usbhost_pio_get_device8_active_gated(uh);
 	} else if (!strcmp(cmd, "status")) {
 		/* read-only command for shell scripts that write then read */
 	} else {
-- 
