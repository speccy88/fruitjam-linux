From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Tue, 16 Jun 2026 19:20:00 -0400
Subject: [PATCH] misc: add Fruit Jam usbhost combined setup probe

Send the SETUP token and DATA0 payload as one CPU-fed PIO TX stream so
Linux function-call latency cannot stretch the token-to-data gap. Drain
the RX FIFO during the combined transmit so the diagnostic can see past
the host self-echo and look for a device ACK before attempting the IN
data stage.
---
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -882,6 +882,75 @@
 	}
 
 	return fj_usbhost_pio_wait_tx_complete(uh);
+}
+
+static int fj_usbhost_pio_capture_drain(struct fruitjam_usbhost *uh, u32 *len)
+{
+	while (!(readl(uh->pio + FJ_PIO_FSTAT) &
+		 FJ_PIO_FSTAT_RXEMPTY(uh->sm_rx))) {
+		if (*len >= FJ_USBHOST_RX_BYTES_MAX)
+			return -EOVERFLOW;
+		uh->last_rx_bytes[(*len)++] =
+			readl(uh->pio + FJ_PIO_RXF(uh->sm_rx)) >> 24;
+	}
+
+	return 0;
+}
+
+static int fj_usbhost_pio_tx_encoded_capture_cpu(struct fruitjam_usbhost *uh,
+						 const u8 *encoded,
+						 u8 encoded_len,
+						 u32 *rx_len)
+{
+	void __iomem *tx_sm = fj_usbhost_pio_sm(uh, uh->sm_tx);
+	u32 waited;
+	int i;
+	int ret;
+
+	memset(uh->last_rx_bytes, 0, sizeof(uh->last_rx_bytes));
+	*rx_len = 0;
+	uh->last_dma_result = -EOPNOTSUPP;
+	uh->last_dma_ctrl = 0;
+	writel(FJ_PIO_IRQ_TX_EOP, uh->pio + FJ_PIO_IRQ);
+	writel(FJ_PIO_FDEBUG_TXSTALL(uh->sm_tx), uh->pio + FJ_PIO_FDEBUG);
+	writel(FJ_PIO_TX_START_INSTR, tx_sm + FJ_PIO_SM_INSTR);
+
+	for (i = 0; i < encoded_len; i++) {
+		ret = fj_usbhost_pio_capture_drain(uh, rx_len);
+		if (ret)
+			return ret;
+		ret = fj_usbhost_pio_write_tx_byte(uh, encoded[i]);
+		if (ret)
+			return ret;
+	}
+
+	for (waited = 0; waited < FJ_USBHOST_TX_TIMEOUT_US; waited++) {
+		u32 irq;
+
+		ret = fj_usbhost_pio_capture_drain(uh, rx_len);
+		if (ret)
+			return ret;
+		irq = readl(uh->pio + FJ_PIO_IRQ);
+		if (irq & FJ_PIO_IRQ_RX_ALL)
+			writel(FJ_PIO_IRQ_RX_ALL, uh->pio + FJ_PIO_IRQ);
+		if (irq & FJ_PIO_IRQ_TX_EOP) {
+			writel(FJ_PIO_IRQ_TX_EOP, uh->pio + FJ_PIO_IRQ);
+			for (waited = 0;
+			     waited < FJ_USBHOST_FIFO_TIMEOUT_US; waited++) {
+				ret = fj_usbhost_pio_capture_drain(uh, rx_len);
+				if (ret)
+					return ret;
+				if ((readl(tx_sm + FJ_PIO_SM_ADDR) & 0x1f) >=
+				    FJ_USB_TX_ENCODED_COMP)
+					return 0;
+				udelay(1);
+			}
+			return 0;
+		}
+		udelay(1);
+	}
+
+	return -ETIMEDOUT;
 }
 
 static u32 fj_usbhost_pio_tx_dreq(struct fruitjam_usbhost *uh)
@@ -1006,6 +1075,29 @@
 	return fj_usbhost_pio_tx_encoded_cpu(uh, encoded, len);
 }
 
+static int fj_usbhost_pio_tx_two_packets_capture_cpu(
+	struct fruitjam_usbhost *uh, const u8 *packet_a, u8 packet_a_len,
+	const u8 *packet_b, u8 packet_b_len, u8 *encoded_len, u32 *rx_len)
+{
+	u8 encoded_a[FJ_USBHOST_TX_ENCODED_MAX];
+	u8 encoded_b[FJ_USBHOST_TX_ENCODED_MAX];
+	u8 encoded[FJ_USBHOST_TX_ENCODED_MAX];
+	u8 len_a;
+	u8 len_b;
+
+	len_a = fj_usbhost_encode_tx(packet_a, packet_a_len, encoded_a);
+	len_b = fj_usbhost_encode_tx(packet_b, packet_b_len, encoded_b);
+	if (len_a > sizeof(encoded) || len_b > sizeof(encoded) ||
+	    len_a + len_b > sizeof(encoded))
+		return -EOVERFLOW;
+
+	memcpy(encoded, encoded_a, len_a);
+	memcpy(encoded + len_a, encoded_b, len_b);
+	*encoded_len = len_a + len_b;
+	return fj_usbhost_pio_tx_encoded_capture_cpu(uh, encoded,
+						     *encoded_len, rx_len);
+}
+
 static int fj_usbhost_pio_send_token(struct fruitjam_usbhost *uh,
 				     u8 pid, u8 addr, u8 ep,
 				     u8 *encoded_len)
@@ -1087,6 +1179,36 @@
 
 	return fj_usbhost_pio_tx_packet_cpu(uh, packet, payload_len + 4,
 					    encoded_len);
+}
+
+static int fj_usbhost_pio_send_setup_data0_combo(struct fruitjam_usbhost *uh,
+						 const u8 *payload,
+						 u8 payload_len,
+						 u8 *encoded_len,
+						 u32 *rx_len)
+{
+	u16 token = 0;
+	u8 setup_packet[4] = { FJ_USB_SYNC, FJ_USB_PID_SETUP, 0, 0 };
+	u8 data_packet[16];
+	u16 crc;
+
+	if (payload_len > 8)
+		return -EINVAL;
+
+	setup_packet[2] = token & 0xff;
+	setup_packet[3] = ((u16)fj_usbhost_crc5_token(token) << 3) |
+			  ((token >> 8) & 0x1f);
+
+	data_packet[0] = FJ_USB_SYNC;
+	data_packet[1] = FJ_USB_PID_DATA0;
+	memcpy(data_packet + 2, payload, payload_len);
+	crc = fj_usbhost_crc16_data(payload, payload_len);
+	data_packet[2 + payload_len] = crc & 0xff;
+	data_packet[3 + payload_len] = crc >> 8;
+
+	return fj_usbhost_pio_tx_two_packets_capture_cpu(
+		uh, setup_packet, sizeof(setup_packet),
+		data_packet, payload_len + 4, encoded_len, rx_len);
 }
 
 static int fj_usbhost_pio_send_ack(struct fruitjam_usbhost *uh)
@@ -1274,6 +1396,46 @@
 #undef FJ_USBHOST_DRAIN_RX_FIFO
 }
 
+static int fj_usbhost_pio_receive_capture(struct fruitjam_usbhost *uh,
+					  u32 max_wait_us, u32 quiet_us,
+					  u32 len)
+{
+	u32 waited;
+	u32 quiet = 0;
+	int ret = -ETIMEDOUT;
+	for (waited = 0; waited < max_wait_us; waited++) {
+		u32 irq;
+		u32 before = len;
+
+		ret = fj_usbhost_pio_capture_drain(uh, &len);
+		if (ret)
+			break;
+		irq = readl(uh->pio + FJ_PIO_IRQ);
+		if (irq & FJ_PIO_IRQ_RX_BS_ERR)
+			ret = -EILSEQ;
+		if (irq & FJ_PIO_IRQ_RX_ALL)
+			writel(FJ_PIO_IRQ_RX_ALL, uh->pio + FJ_PIO_IRQ);
+
+		if (len != before || (irq & (FJ_PIO_IRQ_RX_EOP |
+					     FJ_PIO_IRQ_RX_START)))
+			quiet = 0;
+		else if (len)
+			quiet++;
+
+		if (len && quiet >= quiet_us) {
+			ret = 0;
+			break;
+		}
+		if (ret == -EILSEQ)
+			break;
+		udelay(1);
+	}
+
+	fj_usbhost_pio_sm_disable(uh, uh->sm_rx);
+	fj_usbhost_pio_record_rx(uh, ret, len);
+	return ret;
+}
+
 static int fj_usbhost_pio_require_configured(struct fruitjam_usbhost *uh)
 {
 	if (!fj_usbhost_pio_available(uh))
@@ -1697,7 +1859,66 @@
 	uh->rx_errors++;
 	return ret;
 }
+
+static bool fj_usbhost_rx_has_pid(struct fruitjam_usbhost *uh, u8 pid)
+{
+	u32 i;
 
+	for (i = 1; i < uh->last_rx_len; i++) {
+		if (uh->last_rx_bytes[i] == pid)
+			return true;
+	}
+	return false;
+}
+
+static int fj_usbhost_pio_get_device8_combo(struct fruitjam_usbhost *uh)
+{
+	static const u8 get_device8_setup[8] = {
+		0x80, 0x06, 0x00, 0x01, 0x00, 0x00, 0x08, 0x00,
+	};
+	u8 encoded_len = 0;
+	u32 rx_len = 0;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	fj_usbhost_pio_prepare_receive(uh);
+	fj_usbhost_pio_clear_rx_irq(uh);
+	ret = fj_usbhost_pio_send_setup_data0_combo(uh, get_device8_setup,
+						    sizeof(get_device8_setup),
+						    &encoded_len, &rx_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+
+	ret = fj_usbhost_pio_receive_capture(uh, 500, 80, rx_len);
+	if (ret)
+		return ret;
+	if (!fj_usbhost_rx_has_pid(uh, FJ_USB_PID_ACK)) {
+		fj_usbhost_pio_record_rx(uh, -EPROTO, uh->last_rx_len);
+		return -EPROTO;
+	}
+
+	fj_usbhost_pio_prepare_receive_after_tx(uh);
+	ret = fj_usbhost_pio_send_token(uh, FJ_USB_PID_IN, 0, 0, &encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+	return fj_usbhost_pio_receive_raw(uh, true);
+
+out_error:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->rx_errors++;
+	return ret;
+}
+
 static int fj_usbhost_pio_in_token_gated(struct fruitjam_usbhost *uh)
 {
 	u8 encoded_len = 0;
@@ -1845,6 +2066,13 @@
 	return ret ? ret : fj_usbhost_pio_get_device8_gated(uh);
 }
 
+static int fj_usbhost_pio_get_device8_active_combo(struct fruitjam_usbhost *uh)
+{
+	int ret = fj_usbhost_pio_reset_active(uh);
+
+	return ret ? ret : fj_usbhost_pio_get_device8_combo(uh);
+}
+
 static void fj_usbhost_pio_release(struct fruitjam_usbhost *uh)
 {
 	if (!uh->pio)
@@ -2118,10 +2346,14 @@
 		ret = fj_usbhost_pio_get_device8_gated(uh);
 	} else if (!strcmp(cmd, "get-device-8-gated-cpu")) {
 		ret = fj_usbhost_pio_get_device8_gated_cpu(uh);
+	} else if (!strcmp(cmd, "get-device-8-combo")) {
+		ret = fj_usbhost_pio_get_device8_combo(uh);
 	} else if (!strcmp(cmd, "reset-get-device-8")) {
 		ret = fj_usbhost_pio_get_device8_active(uh);
 	} else if (!strcmp(cmd, "reset-get-device-8-gated")) {
 		ret = fj_usbhost_pio_get_device8_active_gated(uh);
+	} else if (!strcmp(cmd, "reset-get-device-8-combo")) {
+		ret = fj_usbhost_pio_get_device8_active_combo(uh);
 	} else if (!strcmp(cmd, "status")) {
 		/* read-only command for shell scripts that write then read */
 	} else {
