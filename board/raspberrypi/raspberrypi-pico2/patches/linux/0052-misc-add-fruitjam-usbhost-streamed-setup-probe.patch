From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Fred Makes <fred@example.com>
Date: Wed, 17 Jun 2026 00:35:00 +0000
Subject: [PATCH] misc: add fruitjam usbhost streamed setup probe

The Linux-side diagnostic paths send SETUP token and DATA0 as separate PIO
transfers.  That leaves a kernel-controlled gap between the token and data
packet, which can be much wider than a bare-metal Pico-PIO-USB transaction.
Add a diagnostic encoder that streams SETUP and DATA0 through one PIO transfer,
keeps the bus driven through the token-to-data boundary, releases it after
DATA0, and then probes the IN descriptor stage.
---
 drivers/misc/fruitjam_usbhost.c | 209 ++++++++++++++++++++++++++++++++-
 1 file changed, 208 insertions(+), 1 deletion(-)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
index 333333333333..444444444444 100644
@@ -774,7 +774,103 @@
 
 	return bit_idx >> 2;
 }
+
+static int fj_usbhost_append_tx_symbol(u8 *encoded, u16 *bit_idx,
+					       u8 symbol)
+{
+	u16 byte_idx = *bit_idx >> 2;
+
+	if (byte_idx >= FJ_USBHOST_TX_ENCODED_MAX)
+		return -EOVERFLOW;
+	encoded[byte_idx] <<= 2;
+	encoded[byte_idx] |= symbol & 0x3;
+	(*bit_idx)++;
+	return 0;
+}
+
+static int fj_usbhost_encode_tx_packet_stream(const u8 *packet, u8 packet_len,
+					      u8 *encoded, u16 *bit_idx,
+					      bool release_eop)
+{
+	int current_state = 1;
+	int bit_stuffing = 6;
+	int idx;
+	int ret;
+
+	for (idx = 0; idx < packet_len; idx++) {
+		u8 data_byte = packet[idx];
+		int bit;
 
+		for (bit = 0; bit < 8; bit++) {
+			if (data_byte & BIT(bit)) {
+				ret = fj_usbhost_append_tx_symbol(
+					encoded, bit_idx, current_state ?
+					FJ_USB_TX_ENCODED_K : FJ_USB_TX_ENCODED_J);
+				bit_stuffing--;
+			} else {
+				ret = fj_usbhost_append_tx_symbol(
+					encoded, bit_idx, current_state ?
+					FJ_USB_TX_ENCODED_J : FJ_USB_TX_ENCODED_K);
+				current_state = !current_state;
+				bit_stuffing = 6;
+			}
+			if (ret)
+				return ret;
+
+			if (!bit_stuffing) {
+				ret = fj_usbhost_append_tx_symbol(
+					encoded, bit_idx, current_state ?
+					FJ_USB_TX_ENCODED_J : FJ_USB_TX_ENCODED_K);
+				if (ret)
+					return ret;
+				current_state = !current_state;
+				bit_stuffing = 6;
+			}
+		}
+	}
+
+	ret = fj_usbhost_append_tx_symbol(encoded, bit_idx,
+					       FJ_USB_TX_ENCODED_SE0);
+	if (ret || !release_eop)
+		return ret;
+	ret = fj_usbhost_append_tx_symbol(encoded, bit_idx,
+					       FJ_USB_TX_ENCODED_COMP);
+	if (ret)
+		return ret;
+	do {
+		ret = fj_usbhost_append_tx_symbol(encoded, bit_idx,
+					       FJ_USB_TX_ENCODED_K);
+		if (ret)
+			return ret;
+	} while (*bit_idx & 0x03);
+
+	return 0;
+}
+
+static int fj_usbhost_encode_tx_pair_no_release(const u8 *packet_a,
+						u8 packet_a_len,
+						const u8 *packet_b,
+						u8 packet_b_len,
+						u8 *encoded, u8 *encoded_len)
+{
+	u16 bit_idx = 0;
+	int ret;
+
+	memset(encoded, 0, FJ_USBHOST_TX_ENCODED_MAX);
+	ret = fj_usbhost_encode_tx_packet_stream(packet_a, packet_a_len,
+						  encoded, &bit_idx, false);
+	if (ret)
+		return ret;
+	ret = fj_usbhost_encode_tx_packet_stream(packet_b, packet_b_len,
+						  encoded, &bit_idx, true);
+	if (ret)
+		return ret;
+	if (bit_idx & 0x3)
+		return -EIO;
+	*encoded_len = bit_idx >> 2;
+	return 0;
+}
+
 static void fj_usbhost_deassert_reset(struct fruitjam_usbhost *uh, u32 bit)
 {
 	u32 mask = BIT(bit);
@@ -1209,6 +1305,53 @@
 	return fj_usbhost_pio_tx_two_packets_capture_cpu(
 		uh, setup_packet, sizeof(setup_packet),
 		data_packet, payload_len + 4, encoded_len, rx_len);
+}
+
+static int fj_usbhost_pio_tx_two_packets_no_release(
+	struct fruitjam_usbhost *uh, const u8 *packet_a, u8 packet_a_len,
+	const u8 *packet_b, u8 packet_b_len, u8 *encoded_len)
+{
+	u8 encoded[FJ_USBHOST_TX_ENCODED_MAX];
+	int ret;
+
+	ret = fj_usbhost_encode_tx_pair_no_release(packet_a, packet_a_len,
+						    packet_b, packet_b_len,
+						    encoded, encoded_len);
+	if (ret) {
+		*encoded_len = 0;
+		return ret;
+	}
+
+	return fj_usbhost_pio_tx_encoded(uh, encoded, *encoded_len);
+}
+
+static int fj_usbhost_pio_send_setup_data0_stream(struct fruitjam_usbhost *uh,
+						  const u8 *payload,
+						  u8 payload_len,
+						  u8 *encoded_len)
+{
+	u16 token = 0;
+	u8 setup_packet[4] = { FJ_USB_SYNC, FJ_USB_PID_SETUP, 0, 0 };
+	u8 data_packet[16];
+	u16 crc;
+
+	if (payload_len > 8)
+		return -EINVAL;
+
+	setup_packet[2] = token & 0xff;
+	setup_packet[3] = ((u16)fj_usbhost_crc5_token(token) << 3) |
+			  ((token >> 8) & 0x1f);
+
+	data_packet[0] = FJ_USB_SYNC;
+	data_packet[1] = FJ_USB_PID_DATA0;
+	memcpy(data_packet + 2, payload, payload_len);
+	crc = fj_usbhost_crc16_data(payload, payload_len);
+	data_packet[2 + payload_len] = crc & 0xff;
+	data_packet[3 + payload_len] = crc >> 8;
+
+	return fj_usbhost_pio_tx_two_packets_no_release(
+		uh, setup_packet, sizeof(setup_packet),
+		data_packet, payload_len + 4, encoded_len);
 }
 
 static int fj_usbhost_pio_send_ack(struct fruitjam_usbhost *uh)
@@ -2101,7 +2244,55 @@
 	 * Clear any late/stale handshake state, then ask for the first 8 bytes
 	 * of the descriptor.  This makes the result independent from whether
 	 * Linux saw the SETUP ACK in time.
+	 */
+	fj_usbhost_pio_disable_receive(uh);
+	fj_usbhost_pio_prepare_receive_after_tx(uh);
+	ret = fj_usbhost_pio_send_token(uh, FJ_USB_PID_IN, 0, 0, &encoded_len);
+	if (ret) {
+		fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+		return ret;
+	}
+	ret = fj_usbhost_pio_receive_raw(uh, true);
+	fj_usbhost_pio_record_tx(uh, 0, encoded_len);
+	return ret;
+
+out_error:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->rx_errors++;
+	return ret;
+}
+
+static int fj_usbhost_pio_get_device8_stream(struct fruitjam_usbhost *uh)
+{
+	static const u8 get_device8_setup[8] = {
+		0x80, 0x06, 0x00, 0x01, 0x00, 0x00, 0x08, 0x00,
+	};
+	u8 encoded_len = 0;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	/*
+	 * Diagnostic only: keep the host driving the bus between the SETUP
+	 * token and DATA0 packet so Linux scheduling cannot stretch the
+	 * transaction gap beyond what the device accepts.  Ignore the SETUP ACK
+	 * and test success by asking for the descriptor data stage afterwards.
 	 */
+	fj_usbhost_pio_disable_receive(uh);
+	ret = fj_usbhost_pio_send_setup_data0_stream(uh, get_device8_setup,
+						sizeof(get_device8_setup),
+						&encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+
 	fj_usbhost_pio_disable_receive(uh);
 	fj_usbhost_pio_prepare_receive_after_tx(uh);
 	ret = fj_usbhost_pio_send_token(uh, FJ_USB_PID_IN, 0, 0, &encoded_len);
@@ -2213,6 +2404,13 @@
 	return ret ? ret : fj_usbhost_pio_get_device8_burst(uh);
 }
 
+static int fj_usbhost_pio_get_device8_active_stream(struct fruitjam_usbhost *uh)
+{
+	int ret = fj_usbhost_pio_reset_active(uh);
+
+	return ret ? ret : fj_usbhost_pio_get_device8_stream(uh);
+}
+
 static void fj_usbhost_pio_release(struct fruitjam_usbhost *uh)
 {
 	if (!uh->pio)
@@ -2492,6 +2690,8 @@
 		ret = fj_usbhost_pio_get_device8_fast(uh);
 	} else if (!strcmp(cmd, "get-device-8-burst")) {
 		ret = fj_usbhost_pio_get_device8_burst(uh);
+	} else if (!strcmp(cmd, "get-device-8-stream")) {
+		ret = fj_usbhost_pio_get_device8_stream(uh);
 	} else if (!strcmp(cmd, "reset-get-device-8")) {
 		ret = fj_usbhost_pio_get_device8_active(uh);
 	} else if (!strcmp(cmd, "reset-get-device-8-gated")) {
@@ -2502,6 +2702,8 @@
 		ret = fj_usbhost_pio_get_device8_active_fast(uh);
 	} else if (!strcmp(cmd, "reset-get-device-8-burst")) {
 		ret = fj_usbhost_pio_get_device8_active_burst(uh);
+	} else if (!strcmp(cmd, "reset-get-device-8-stream")) {
+		ret = fj_usbhost_pio_get_device8_active_stream(uh);
 	} else if (!strcmp(cmd, "status")) {
 		/* read-only command for shell scripts that write then read */
 	} else {
-- 
