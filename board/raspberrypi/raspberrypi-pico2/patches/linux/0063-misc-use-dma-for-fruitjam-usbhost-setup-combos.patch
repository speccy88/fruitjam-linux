From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Wed, 17 Jun 2026 13:05:00 +0000
Subject: [PATCH] misc: use DMA for Fruit Jam usbhost setup combos

The combined SETUP-token/DATA0 diagnostic path used CPU FIFO writes so it
could drain the local RX FIFO at the same time. That is useful for capture
debugging, but it can underrun the TX FIFO and stretch bits in the middle of a
USB packet. The DMA "stream" diagnostic avoided CPU gaps but intentionally
omitted the first packet's normal release/EOP, so it was not a valid setup
transaction either.

Add a DMA-backed two-packet sender that keeps both packets normally encoded:
SETUP token with EOP/release followed by DATA0 with EOP/release. Use that path
for the skip-ACK descriptor probe and for no-data control transfers, where the
following IN/status stage proves whether the device accepted the setup.  Since
there is one TX-EOP per packet, wait for final TX idle before returning from the
two-packet DMA helper; otherwise the next control stage can start while the
DATA0 packet is still draining through the TX FIFO.
---
 drivers/misc/fruitjam_usbhost.c | 83 ++++++++++++++++++++++++-----------------
 1 file changed, 50 insertions(+), 33 deletions(-)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -1384,6 +1384,33 @@ static int fj_usbhost_pio_tx_two_packets_capture_cpu(
 						     *encoded_len, rx_len);
 }
 
+static int fj_usbhost_pio_tx_two_packets_dma(
+	struct fruitjam_usbhost *uh, const u8 *packet_a, u8 packet_a_len,
+	const u8 *packet_b, u8 packet_b_len, u8 *encoded_len)
+{
+	u8 encoded_a[FJ_USBHOST_TX_ENCODED_MAX];
+	u8 encoded_b[FJ_USBHOST_TX_ENCODED_MAX];
+	u8 encoded[FJ_USBHOST_TX_ENCODED_MAX];
+	u8 len_a;
+	u8 len_b;
+	int ret;
+
+	len_a = fj_usbhost_encode_tx(packet_a, packet_a_len, encoded_a);
+	len_b = fj_usbhost_encode_tx(packet_b, packet_b_len, encoded_b);
+	if (len_a > sizeof(encoded) || len_b > sizeof(encoded) ||
+	    len_a + len_b > sizeof(encoded))
+		return -EOVERFLOW;
+
+	memcpy(encoded, encoded_a, len_a);
+	memcpy(encoded + len_a, encoded_b, len_b);
+	*encoded_len = len_a + len_b;
+
+	ret = fj_usbhost_pio_tx_encoded(uh, encoded, *encoded_len);
+	if (ret)
+		return ret;
+	return fj_usbhost_pio_wait_tx_stream_idle(uh);
+}
+
 static int fj_usbhost_pio_send_token(struct fruitjam_usbhost *uh,
 				     u8 pid, u8 addr, u8 ep,
 				     u8 *encoded_len)
@@ -1497,12 +1520,9 @@ static int fj_usbhost_pio_send_setup_data0_combo(struct fruitjam_usbhost *uh,
 		data_packet, payload_len + 4, encoded_len, rx_len);
 }
 
-static int fj_usbhost_pio_send_setup_data0_combo_addr(struct fruitjam_usbhost *uh,
-						      u8 addr,
-						      const u8 *payload,
-						      u8 payload_len,
-						      u8 *encoded_len,
-						      u32 *rx_len)
+static int fj_usbhost_pio_send_setup_data0_combo_dma_addr(
+	struct fruitjam_usbhost *uh, u8 addr, const u8 *payload, u8 payload_len,
+	u8 *encoded_len)
 {
 	u16 token = addr & 0x7f;
 	u8 setup_packet[4] = { FJ_USB_SYNC, FJ_USB_PID_SETUP, 0, 0 };
@@ -1523,11 +1543,16 @@ static int fj_usbhost_pio_send_setup_data0_combo_addr(struct fruitjam_usbhost *u
 	data_packet[2 + payload_len] = crc & 0xff;
 	data_packet[3 + payload_len] = crc >> 8;
 
-	return fj_usbhost_pio_tx_two_packets_capture_cpu(
-		uh, setup_packet, sizeof(setup_packet),
-		data_packet, payload_len + 4, encoded_len, rx_len);
+	/*
+	 * This is the non-capture path: keep the transaction timing in PIO/DMA
+	 * and validate success with the following data/status stage.
+	 */
+	return fj_usbhost_pio_tx_two_packets_dma(
+		uh, setup_packet, sizeof(setup_packet),
+		data_packet, payload_len + 4, encoded_len);
 }
 
+
 static int fj_usbhost_pio_tx_two_packets_no_release(
 	struct fruitjam_usbhost *uh, const u8 *packet_a, u8 packet_a_len,
 	const u8 *packet_b, u8 packet_b_len, u8 *encoded_len)
@@ -2410,8 +2435,6 @@ static int fj_usbhost_pio_get_device8_combo_skipack(struct fruitjam_usbhost *uh)
 		0x80, 0x06, 0x00, 0x01, 0x00, 0x00, 0x08, 0x00,
 	};
 	u8 encoded_len = 0;
-	u32 setup_rx_len = 0;
-	u32 setup_rx_pid = 0;
 	int ret;
 
 	ret = fj_usbhost_pio_require_configured(uh);
@@ -2424,20 +2447,16 @@ static int fj_usbhost_pio_get_device8_combo_skipack(struct fruitjam_usbhost *uh)
 	 * turnaround is too small for a CPU-side decision path; the following IN
 	 * stage tells us whether the device accepted the setup anyway.
 	 */
-	fj_usbhost_pio_prepare_receive(uh);
-	fj_usbhost_pio_clear_rx_irq(uh);
-	ret = fj_usbhost_pio_send_setup_data0_combo(uh, get_device8_setup,
-						    sizeof(get_device8_setup),
-						    &encoded_len,
-						    &setup_rx_len);
+	fj_usbhost_pio_disable_receive(uh);
+	ret = fj_usbhost_pio_send_setup_data0_combo_dma_addr(
+		uh, 0, get_device8_setup, sizeof(get_device8_setup),
+		&encoded_len);
 	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
 	if (ret)
 		return ret;
 
-	setup_rx_pid = setup_rx_len >= 2 ? uh->last_rx_bytes[1] : 0;
 	scnprintf(uh->last_probe_summary, sizeof(uh->last_probe_summary),
-		  "combo-skipack setup-rx-len=%u setup-rx-pid=0x%02x",
-		  setup_rx_len, setup_rx_pid);
+		  "combo-dma-skipack setup-tx-len=%u", encoded_len);
 
 	fj_usbhost_pio_prepare_receive_after_tx(uh);
 	ret = fj_usbhost_pio_send_token(uh, FJ_USB_PID_IN, 0, 0, &encoded_len);
@@ -2500,28 +2519,21 @@ static int fj_usbhost_pio_control_no_data(struct fruitjam_usbhost *uh,
 		0x00, 0x00,
 	};
 	u8 encoded_len = 0;
-	u32 setup_rx_len = 0;
-	u32 setup_rx_pid = 0;
 	int ret;
 
 	ret = fj_usbhost_pio_require_configured(uh);
 	if (ret)
 		goto out_error;
 
-	fj_usbhost_pio_prepare_receive(uh);
-	fj_usbhost_pio_clear_rx_irq(uh);
-	ret = fj_usbhost_pio_send_setup_data0_combo_addr(uh, addr, setup,
-							 sizeof(setup),
-							 &encoded_len,
-							 &setup_rx_len);
+	fj_usbhost_pio_disable_receive(uh);
+	ret = fj_usbhost_pio_send_setup_data0_combo_dma_addr(
+		uh, addr, setup, sizeof(setup), &encoded_len);
 	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
 	if (ret)
 		return ret;
 
-	setup_rx_pid = setup_rx_len >= 2 ? uh->last_rx_bytes[1] : 0;
 	scnprintf(uh->last_probe_summary, sizeof(uh->last_probe_summary),
-		  "%s setup-rx-len=%u setup-rx-pid=0x%02x",
-		  name, setup_rx_len, setup_rx_pid);
+		  "%s setup-dma-tx-len=%u", name, encoded_len);
 
 	ret = fj_usbhost_pio_control_status_in(uh, addr);
 	if (!ret)
-- 
2.39.5
