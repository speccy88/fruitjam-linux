From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Wed, 17 Jun 2026 16:10:00 -0400
Subject: [PATCH] misc: add Fruit Jam usbhost CPU SOF self-RX

The 252 MHz wili8jam-style image boots and detects the host-port line state,
but the plain self-RX probe exercises the DMA-fed transmit path first.  Add a
CPU-fed SOF self-RX diagnostic so hardware tests can split DMA handoff issues
from PIO/RX timing issues without changing the normal DMA path.
---
 drivers/misc/fruitjam_usbhost.c | 46 +++++++++++++++++++++++++++++++++
 1 file changed, 46 insertions(+)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
index 111111111111..222222222222 100644
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -2268,6 +2268,52 @@ out_error:
 	return ret;
 }
 
+static int fj_usbhost_pio_self_rx_cpu(struct fruitjam_usbhost *uh)
+{
+	u8 packet[4] = { FJ_USB_SYNC, FJ_USB_PID_SOF, 0, 0 };
+	u16 frame = uh->packets & 0x7ff;
+	u16 token = frame;
+	u8 encoded_len = 0;
+	int ret;
+
+	ret = fj_usbhost_pio_require_configured(uh);
+	if (ret)
+		goto out_error;
+
+	packet[2] = token & 0xff;
+	packet[3] = ((u16)fj_usbhost_crc5_token(token) << 3) |
+		    ((token >> 8) & 0x7);
+
+	fj_usbhost_pio_prepare_receive(uh);
+	fj_usbhost_pio_clear_rx_irq(uh);
+	ret = fj_usbhost_pio_tx_packet_cpu(uh, packet, sizeof(packet),
+					    &encoded_len);
+	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
+	if (ret)
+		return ret;
+
+	/*
+	 * This is the same SOF loopback-style probe as self-rx, except the
+	 * transmit FIFO is fed by the CPU instead of DMA.
+	 */
+	return fj_usbhost_pio_receive_raw(uh, false);
+
+out_error:
+	uh->last_tx_result = ret;
+	uh->last_tx_len = 0;
+	uh->tx_errors++;
+	uh->last_rx_result = ret;
+	uh->last_rx_len = 0;
+	uh->last_rx_pid = 0;
+	uh->last_rx_irq = uh->pio ? readl(uh->pio + FJ_PIO_IRQ) : 0;
+	uh->last_rx_flevel = uh->pio ? readl(uh->pio + FJ_PIO_FLEVEL) : 0;
+	uh->last_pio_fstat = uh->pio ? readl(uh->pio + FJ_PIO_FSTAT) : 0;
+	uh->last_pio_fdebug = uh->pio ? readl(uh->pio + FJ_PIO_FDEBUG) : 0;
+	uh->last_pio_irq = uh->last_rx_irq;
+	uh->rx_errors++;
+	return ret;
+}
+
 static int fj_usbhost_pio_in_token(struct fruitjam_usbhost *uh)
 {
 	u8 encoded_len = 0;
@@ -4137,6 +4179,8 @@ static ssize_t fj_usbhost_write(struct file *file, const char __user *buf,
 		ret = fj_usbhost_pio_tx_test(uh);
 	} else if (!strcmp(cmd, "self-rx")) {
 		ret = fj_usbhost_pio_self_rx(uh);
+	} else if (!strcmp(cmd, "self-rx-cpu")) {
+		ret = fj_usbhost_pio_self_rx_cpu(uh);
 	} else if (!strcmp(cmd, "sof-burst")) {
 		ret = fj_usbhost_pio_sof_burst(uh, FJ_USBHOST_SOF_BURST_FRAMES);
 	} else if (!strcmp(cmd, "in-token")) {
