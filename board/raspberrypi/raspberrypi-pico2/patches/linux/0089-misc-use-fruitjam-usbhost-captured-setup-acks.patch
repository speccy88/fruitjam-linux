From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Thu, 18 Jun 2026 04:05:00 +0000
Subject: [PATCH] misc: use Fruit Jam usbhost captured setup ACKs

Pico-PIO-USB can clear/release its receive state immediately after the DATA0
stage of a SETUP transaction because it runs the transaction loop on bare
metal. The Linux bridge tried to emulate that by arming RX after the first
host EOP, but the resulting host-token to DATA0 gap can be too long for the
device while a post-DATA0 CPU-side receive can be too late to see the ACK.

Reuse the stream-capture path for HCD control setup stages instead: keep the
SETUP token and DATA0 packet in one DMA stream, poll/clear RX IRQs tightly
while DMA is active, then scan the captured bytes for an ACK. This is still a
small synchronous HCD path, but it matches the existing diagnostic that was
designed to observe host echoes plus a device response without depending on a
late receive gate.
---
 drivers/misc/fruitjam_usbhost.c | 51 +++++++++++++++++++++------------
 1 file changed, 33 insertions(+), 18 deletions(-)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -1404,10 +1404,11 @@
 				ret = 0;
 				break;
 			}
+			udelay(1);
 		} else {
 			quiet = 0;
+			cpu_relax();
 		}
-		udelay(1);
 	}
 
 	for (waited = 0; waited < FJ_USBHOST_DMA_TIMEOUT_US; waited++) {
@@ -3162,32 +3163,36 @@
 		0x00, 0x00,
 	};
 	u8 encoded_len = 0;
+	u32 setup_rx_len = 0;
 	int ret;
 
 	ret = fj_usbhost_pio_require_configured(uh);
 	if (ret)
 		goto out_error;
 
-	fj_usbhost_pio_disable_receive(uh);
-	ret = fj_usbhost_pio_send_setup_data0_dma_addr_arm_ack(
-		uh, addr, setup, sizeof(setup), &encoded_len);
+	fj_usbhost_pio_prepare_receive(uh);
+	fj_usbhost_pio_clear_rx_irq(uh);
+	ret = fj_usbhost_pio_send_setup_data0_capture_dma_addr(
+		uh, addr, setup, sizeof(setup), &encoded_len, &setup_rx_len);
 	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
 	if (ret)
 		return ret;
 
 	scnprintf(uh->last_probe_summary, sizeof(uh->last_probe_summary),
-		  "%s setup-arm-ack tx-len=%u", name, encoded_len);
+		  "%s setup-capture tx-len=%u rx-len=%u", name,
+		  encoded_len, setup_rx_len);
 
-	ret = fj_usbhost_pio_receive_raw(uh, false);
+	ret = fj_usbhost_pio_receive_capture(uh, 100, 8, setup_rx_len);
 	if (ret)
 		return ret;
-	if (uh->last_rx_pid != FJ_USB_PID_ACK) {
+	if (!fj_usbhost_rx_has_pid(uh, FJ_USB_PID_ACK)) {
 		fj_usbhost_pio_record_rx(uh, -EPROTO, uh->last_rx_len);
 		return -EPROTO;
 	}
 
 	scnprintf(uh->last_probe_summary, sizeof(uh->last_probe_summary),
-		  "%s setup-ack-ok tx-len=%u", name, encoded_len);
+		  "%s setup-capture-ack tx-len=%u rx-len=%u", name,
+		  encoded_len, uh->last_rx_len);
 
 	ret = fj_usbhost_pio_control_status_in(uh, addr);
 	if (!ret)
@@ -3317,6 +3322,7 @@
 	u8 expected_pid;
 	u32 copied;
 	u32 attempt;
+	u32 setup_rx_len;
 	int last_ret = -ETIMEDOUT;
 	int ret;
 
@@ -3343,14 +3349,18 @@
 		if (ret)
 			return ret;
 
-		fj_usbhost_pio_disable_receive(uh);
-		ret = fj_usbhost_pio_send_setup_data0_dma_addr_arm_ack(
-			uh, addr, setup, 8, &encoded_len);
+		setup_rx_len = 0;
+		fj_usbhost_pio_prepare_receive(uh);
+		fj_usbhost_pio_clear_rx_irq(uh);
+		ret = fj_usbhost_pio_send_setup_data0_capture_dma_addr(
+			uh, addr, setup, 8, &encoded_len, &setup_rx_len);
 		fj_usbhost_pio_record_tx(uh, ret, encoded_len);
 		if (ret)
 			return ret;
-		ret = fj_usbhost_pio_receive_raw(uh, false);
-		if (!ret && uh->last_rx_pid == FJ_USB_PID_ACK) {
+
+		ret = fj_usbhost_pio_receive_capture(uh, 100, 8,
+						     setup_rx_len);
+		if (!ret && fj_usbhost_rx_has_pid(uh, FJ_USB_PID_ACK)) {
 			setup_seen = true;
 		} else if (!ret) {
 			fj_usbhost_pio_record_rx(uh, -EPROTO,
@@ -3360,10 +3370,16 @@
 		if (ret) {
 			scnprintf(uh->last_probe_summary,
 				  sizeof(uh->last_probe_summary),
-				  "hcd-control-read setup addr=%u len=%u attempt=%u ret=%d pid=0x%02x",
+				  "hcd-control-read setup-capture addr=%u len=%u attempt=%u ret=%d pid=0x%02x rx-len=%u",
 				  addr, len, attempt + 1, ret,
-				  uh->last_rx_pid);
+				  uh->last_rx_pid, uh->last_rx_len);
 			last_ret = ret;
+		} else {
+			scnprintf(uh->last_probe_summary,
+				  sizeof(uh->last_probe_summary),
+				  "hcd-control-read setup-capture-ack addr=%u len=%u attempt=%u rx-len=%u",
+				  addr, len, attempt + 1,
+				  uh->last_rx_len);
 		}
 		if (ret)
 			continue;
-- 
2.39.5
