From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Fruit Jam Linux <fruitjam-linux@local>
Date: Thu, 18 Jun 2026 01:15:00 -0400
Subject: [PATCH] misc: sweep Fruit Jam usbhost HCD ACK arm gap

Hardware testing showed that both the 16-byte and 4-byte HCD ACK-arm pads
cleanly transmit SETUP+DATA0 but still time out waiting for the CH334F hub ACK.
Avoid burning one flash cycle per timing guess: keep the default 4-byte pad for
non-swept helpers, but let HCD control-read retries sweep several gaps and
report the active gap in the probe summary.

The zero-byte case is intentionally included. It is unlikely to give the CPU
enough time to arm RX after the first EOP, but it proves whether the inter-packet
gap itself is the reason the hub is rejecting the setup transaction.
---
 drivers/misc/fruitjam_usbhost.c | 57 ++++++++++++++++++++++++++++----
 1 file changed, 51 insertions(+), 6 deletions(-)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -74,7 +74,9 @@
 #define FJ_USBHOST_SETUP_GAP_MAX_BYTES 16u
 #define FJ_USBHOST_SETUP_GAP_IDLE_FULL_BYTE 0xffu
 #define FJ_USBHOST_SETUP_GAP_IDLE_LOW_BYTE 0x55u
-#define FJ_USBHOST_HCD_ACK_ARM_GAP_BYTES 4u
+#define FJ_USBHOST_HCD_ACK_ARM_GAP_DEFAULT_BYTES 4u
+#define FJ_USBHOST_HCD_ACK_ARM_GAP_SWEEP_MAX_BYTES 16u
+#define FJ_USBHOST_HCD_ACK_ARM_GAP_SWEEP_COUNT 8u
 #define FJ_USBHOST_FRAME_RETRY_DEFAULT 8u
 #define FJ_USBHOST_FRAME_RETRY_MAX 64u
 #define FJ_USBHOST_HANDSHAKE_PACKET_TIMEOUT_US 20u
@@ -1576,9 +1578,18 @@ static int fj_usbhost_pio_tx_two_packets_dma(
 	return fj_usbhost_pio_wait_tx_stream_idle(uh);
 }
 
+static u8 fj_usbhost_hcd_ack_arm_gap_for_attempt(u32 attempt)
+{
+	static const u8 gaps[FJ_USBHOST_HCD_ACK_ARM_GAP_SWEEP_COUNT] = {
+		4, 2, 1, 0, 8, 12, 16, 6,
+	};
+
+	return gaps[attempt % (sizeof(gaps) / sizeof(gaps[0]))];
+}
+
 static int fj_usbhost_pio_tx_two_packets_dma_arm_rx_after_first_eop(
 	struct fruitjam_usbhost *uh, const u8 *packet_a, u8 packet_a_len,
-	const u8 *packet_b, u8 packet_b_len, u8 *encoded_len)
+	const u8 *packet_b, u8 packet_b_len, u8 arm_gap, u8 *encoded_len)
 {
 	u8 encoded_a[FJ_USBHOST_TX_ENCODED_MAX];
 	u8 encoded_b[FJ_USBHOST_TX_ENCODED_MAX];
@@ -1595,9 +1610,10 @@ static int fj_usbhost_pio_tx_two_packets_dma_arm_rx_after_first_eop(
 
 	len_a = fj_usbhost_encode_tx(packet_a, packet_a_len, encoded_a);
 	len_b = fj_usbhost_encode_tx(packet_b, packet_b_len, encoded_b);
+	if (arm_gap > FJ_USBHOST_HCD_ACK_ARM_GAP_SWEEP_MAX_BYTES)
+		return -EINVAL;
 	if (len_a > sizeof(encoded) || len_b > sizeof(encoded) ||
-	    len_a + FJ_USBHOST_HCD_ACK_ARM_GAP_BYTES + len_b >
-		    sizeof(encoded))
+	    len_a + arm_gap + len_b > sizeof(encoded))
 		return -EOVERFLOW;
 	if (!uh->dma || !uh->pio_phys || ch > 15)
 		return -ENODEV;
@@ -1611,10 +1628,9 @@ static int fj_usbhost_pio_tx_two_packets_dma_arm_rx_after_first_eop(
 	idle_byte = uh->low_speed ? FJ_USBHOST_SETUP_GAP_IDLE_LOW_BYTE :
 				    FJ_USBHOST_SETUP_GAP_IDLE_FULL_BYTE;
 	memcpy(encoded, encoded_a, len_a);
-	memset(encoded + len_a, idle_byte, FJ_USBHOST_HCD_ACK_ARM_GAP_BYTES);
-	memcpy(encoded + len_a + FJ_USBHOST_HCD_ACK_ARM_GAP_BYTES, encoded_b,
-	       len_b);
-	*encoded_len = len_a + FJ_USBHOST_HCD_ACK_ARM_GAP_BYTES + len_b;
+	memset(encoded + len_a, idle_byte, arm_gap);
+	memcpy(encoded + len_a + arm_gap, encoded_b, len_b);
+	*encoded_len = len_a + arm_gap + len_b;
 
 	fj_usbhost_dma_abort(uh);
 	memcpy(uh->tx_dma_buf, encoded, *encoded_len);
@@ -1885,7 +1901,7 @@ static int fj_usbhost_pio_send_setup_data0_capture_dma_addr(
 
 static int fj_usbhost_pio_send_setup_data0_dma_addr_arm_ack(
 	struct fruitjam_usbhost *uh, u8 addr, const u8 *payload, u8 payload_len,
-	u8 *encoded_len)
+	u8 arm_gap, u8 *encoded_len)
 {
 	u16 token = addr & 0x7f;
 	u8 setup_packet[4] = { FJ_USB_SYNC, FJ_USB_PID_SETUP, 0, 0 };
@@ -1908,7 +1924,7 @@ static int fj_usbhost_pio_send_setup_data0_dma_addr_arm_ack(
 
 	return fj_usbhost_pio_tx_two_packets_dma_arm_rx_after_first_eop(
 		uh, setup_packet, sizeof(setup_packet),
-		data_packet, payload_len + 4, encoded_len);
+		data_packet, payload_len + 4, arm_gap, encoded_len);
 }
 
 static int fj_usbhost_pio_tx_two_packets_no_release(
@@ -3163,6 +3179,7 @@ static int fj_usbhost_pio_control_no_data(struct fruitjam_usbhost *uh,
 		0x00, 0x00,
 	};
 	u8 encoded_len = 0;
+	u8 arm_gap = FJ_USBHOST_HCD_ACK_ARM_GAP_DEFAULT_BYTES;
 	int ret;
 
 	ret = fj_usbhost_pio_require_configured(uh);
@@ -3170,13 +3187,13 @@ static int fj_usbhost_pio_control_no_data(struct fruitjam_usbhost *uh,
 
 	fj_usbhost_pio_disable_receive(uh);
 	ret = fj_usbhost_pio_send_setup_data0_dma_addr_arm_ack(
-		uh, addr, setup, sizeof(setup), &encoded_len);
+		uh, addr, setup, sizeof(setup), arm_gap, &encoded_len);
 	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
 	if (ret)
 		return ret;
 
 	scnprintf(uh->last_probe_summary, sizeof(uh->last_probe_summary),
-		  "%s setup-arm-ack tx-len=%u", name, encoded_len);
+		  "%s setup-arm-ack gap=%u tx-len=%u", name, arm_gap, encoded_len);
 
 	ret = fj_usbhost_pio_receive_raw(uh, false);
 	if (ret)
@@ -3189,7 +3206,7 @@ static int fj_usbhost_pio_control_no_data(struct fruitjam_usbhost *uh,
 	}
 
 	scnprintf(uh->last_probe_summary, sizeof(uh->last_probe_summary),
-		  "%s setup-ack-ok tx-len=%u", name, encoded_len);
+		  "%s setup-ack-ok gap=%u tx-len=%u", name, arm_gap, encoded_len);
 
 	ret = fj_usbhost_pio_control_status_in(uh, addr);
 	if (!ret)
@@ -3291,7 +3308,8 @@ static int fj_usbhost_pio_control_status_out(struct fruitjam_usbhost *uh,
 
 	ret = fj_usbhost_pio_tx_two_packets_dma_arm_rx_after_first_eop(
 		uh, out_packet, sizeof(out_packet),
-		data_packet, sizeof(data_packet), &encoded_len);
+		data_packet, sizeof(data_packet),
+		FJ_USBHOST_HCD_ACK_ARM_GAP_DEFAULT_BYTES, &encoded_len);
 	fj_usbhost_pio_record_tx(uh, ret, encoded_len);
 	if (ret)
 		return ret;
@@ -3331,6 +3349,7 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 
 	for (attempt = 0; attempt < FJ_USBHOST_HCD_CONTROL_ATTEMPTS;
 	     attempt++) {
+		u8 arm_gap = fj_usbhost_hcd_ack_arm_gap_for_attempt(attempt);
 		bool setup_seen = false;
 
 		encoded_len = 0;
@@ -3343,7 +3362,7 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 
 		fj_usbhost_pio_disable_receive(uh);
 		ret = fj_usbhost_pio_send_setup_data0_dma_addr_arm_ack(
-			uh, addr, setup, 8, &encoded_len);
+			uh, addr, setup, 8, arm_gap, &encoded_len);
 		fj_usbhost_pio_record_tx(uh, ret, encoded_len);
 		if (ret)
 			return ret;
@@ -3361,15 +3380,17 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 		if (ret) {
 			scnprintf(uh->last_probe_summary,
 				  sizeof(uh->last_probe_summary),
-				  "hcd-control-read setup-arm-ack addr=%u len=%u attempt=%u ret=%d pid=0x%02x rx-len=%u",
-				  addr, len, attempt + 1, ret,
+				  "hcd-control-read setup-arm-ack addr=%u len=%u attempt=%u gap=%u tx-len=%u ret=%d pid=0x%02x rx-len=%u",
+				  addr, len, attempt + 1, arm_gap,
+				  encoded_len, ret,
 				  uh->last_rx_pid, uh->last_rx_len);
 			last_ret = ret;
 		} else {
 			scnprintf(uh->last_probe_summary,
 				  sizeof(uh->last_probe_summary),
-				  "hcd-control-read setup-ack-ok addr=%u len=%u attempt=%u rx-len=%u",
-				  addr, len, attempt + 1,
+				  "hcd-control-read setup-ack-ok addr=%u len=%u attempt=%u gap=%u tx-len=%u rx-len=%u",
+				  addr, len, attempt + 1, arm_gap,
+				  encoded_len,
 				  uh->last_rx_len);
 		}
 		if (ret)
@@ -3408,9 +3429,10 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 			if (ret) {
 				scnprintf(uh->last_probe_summary,
 					  sizeof(uh->last_probe_summary),
-					  "hcd-control-read data addr=%u len=%u attempt=%u ret=%d pid=0x%02x setup-ack=%u",
-					  addr, len, attempt + 1, ret,
-					  uh->last_rx_pid,
+					  "hcd-control-read data addr=%u len=%u attempt=%u gap=%u ret=%d pid=0x%02x setup-ack=%u",
+					  addr, len, attempt + 1,
+					  arm_gap, ret,
+					  uh->last_rx_pid,
 					  setup_seen ? 1 : 0);
 				last_ret = ret;
 				break;
@@ -3440,8 +3462,9 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 						uh->last_probe_summary,
 						sizeof(uh->last_probe_summary),
-						"hcd-control-read ok addr=%u requested=%u actual=%u attempt=%u setup-ack=%u",
+						"hcd-control-read ok addr=%u requested=%u actual=%u attempt=%u gap=%u setup-ack=%u",
 						addr, len, copied,
-						attempt + 1,
+						attempt + 1,
+						arm_gap,
 						setup_seen ? 1 : 0);
 				}
 				return ret;
-- 
2.39.5
