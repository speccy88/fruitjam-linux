From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Fruit Jam Linux <fruitjam-linux@local>
Date: Thu, 18 Jun 2026 02:05:00 -0400
Subject: [PATCH] misc: use upstream-style Fruit Jam HCD setup probe

The working wili8jam/TinyUSB path prepares RX, emits SETUP, emits DATA0, then
starts/waits for the handshake. The Linux HCD path was only using the local
gated ACK-arm variant, so a failed enumeration could not prove whether the
Pico-PIO-USB ordering itself helps the CH334F hub.

Try one upstream-style setup stage before sweeping the existing ACK-arm gaps.
Keep the modes named in the probe summary so one flashed image can distinguish
"upstream-style echo/timeout" from "arm-gap timeout" without another rebuild.
---
 drivers/misc/fruitjam_usbhost.c | 79 ++++++++++++++++++++++++++++++++--------
 1 file changed, 64 insertions(+), 15 deletions(-)

diff --git a/drivers/misc/fruitjam_usbhost.c b/drivers/misc/fruitjam_usbhost.c
--- a/drivers/misc/fruitjam_usbhost.c
+++ b/drivers/misc/fruitjam_usbhost.c
@@ -56,7 +56,7 @@
 #define FJ_USBHOST_FIFO_TIMEOUT_US	1000u
 #define FJ_USBHOST_HCD_MAXPACKET	8u
 #define FJ_USBHOST_HCD_POWER_BUDGET	500u
-#define FJ_USBHOST_HCD_CONTROL_ATTEMPTS 8u
+#define FJ_USBHOST_HCD_CONTROL_ATTEMPTS 9u
 #define FJ_USBHOST_HCD_IN_NAK_ATTEMPTS 16u
 #define FJ_USBHOST_HCD_IDLE_SLEEP_MS	20u
 #define FJ_USBHOST_TX_ENCODED_MAX	96u
@@ -1921,7 +1921,38 @@ static int fj_usbhost_pio_send_setup_data0_dma_addr_arm_ack(
 		uh, setup_packet, sizeof(setup_packet),
 		data_packet, payload_len + 4, arm_gap, encoded_len);
 }
+
+static int fj_usbhost_pio_send_setup_data0_upstream_addr(
+	struct fruitjam_usbhost *uh, u8 addr, const u8 *payload, u8 payload_len,
+	u8 *encoded_len)
+{
+	u8 token_len = 0;
+	u8 data_len = 0;
+	int ret;
+
+	if (payload_len > 8)
+		return -EINVAL;
 
+	/*
+	 * Match Pico-PIO-USB's host setup stage: prepare RX, send SETUP,
+	 * send DATA0, then clear RX IRQs and wait for the handshake.
+	 */
+	fj_usbhost_pio_prepare_receive(uh);
+	ret = fj_usbhost_pio_send_token(uh, FJ_USB_PID_SETUP, addr, 0,
+					&token_len);
+	*encoded_len = token_len;
+	if (ret)
+		return ret;
+
+	ret = fj_usbhost_pio_send_data0(uh, payload, payload_len, &data_len);
+	*encoded_len = token_len + data_len;
+	if (ret)
+		return ret;
+
+	fj_usbhost_pio_start_receive(uh);
+	return 0;
+}
+
 static int fj_usbhost_pio_tx_two_packets_no_release(
 	struct fruitjam_usbhost *uh, const u8 *packet_a, u8 packet_a_len,
 	const u8 *packet_b, u8 packet_b_len, u8 *encoded_len)
@@ -3342,8 +3373,13 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 
 	for (attempt = 0; attempt < FJ_USBHOST_HCD_CONTROL_ATTEMPTS;
 	     attempt++) {
-		u8 arm_gap = fj_usbhost_hcd_ack_arm_gap_for_attempt(attempt);
+		bool upstream_mode = attempt == 0;
+		u32 gap_attempt = upstream_mode ? 0 : attempt - 1;
+		u8 arm_gap = fj_usbhost_hcd_ack_arm_gap_for_attempt(gap_attempt);
+		u8 report_gap = upstream_mode ? 0 : arm_gap;
 		bool setup_seen = false;
+		const char *mode = upstream_mode ? "mode=upstream" :
+						 "mode=arm-gap";
 
 		encoded_len = 0;
 		expected_pid = FJ_USB_PID_DATA1;
@@ -3356,14 +3392,21 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 		if (ret)
 			return ret;
 
-		fj_usbhost_pio_disable_receive(uh);
-		ret = fj_usbhost_pio_send_setup_data0_dma_addr_arm_ack(
-			uh, addr, setup, 8, arm_gap, &encoded_len);
+		if (upstream_mode) {
+			ret = fj_usbhost_pio_send_setup_data0_upstream_addr(
+				uh, addr, setup, 8, &encoded_len);
+		} else {
+			fj_usbhost_pio_disable_receive(uh);
+			ret = fj_usbhost_pio_send_setup_data0_dma_addr_arm_ack(
+				uh, addr, setup, 8, arm_gap, &encoded_len);
+		}
 		fj_usbhost_pio_record_tx(uh, ret, encoded_len);
 		if (ret)
 			return ret;
 
-		ret = fj_usbhost_pio_receive_raw(uh, false);
+		ret = upstream_mode ?
+		      fj_usbhost_pio_wait_handshake_fast(uh) :
+		      fj_usbhost_pio_receive_raw(uh, false);
 		if (!ret && uh->last_rx_pid == FJ_USB_PID_ACK) {
 			setup_seen = true;
 		} else if (!ret) {
@@ -3374,16 +3417,17 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 		if (ret) {
 			scnprintf(uh->last_probe_summary,
 				  sizeof(uh->last_probe_summary),
-				  "hcd-control-read setup-arm-ack addr=%u len=%u attempt=%u gap=%u tx-len=%u ret=%d pid=0x%02x rx-len=%u",
-				  addr, len, attempt + 1, arm_gap,
+				  "hcd-control-read setup-fail %s addr=%u len=%u attempt=%u gap=%u tx-len=%u ret=%d pid=0x%02x rx-len=%u",
+				  mode, addr, len, attempt + 1, report_gap,
 				  encoded_len, ret,
 				  uh->last_rx_pid, uh->last_rx_len);
 			last_ret = ret;
 		} else {
 			scnprintf(uh->last_probe_summary,
 				  sizeof(uh->last_probe_summary),
-				  "hcd-control-read setup-ack-ok addr=%u len=%u attempt=%u gap=%u tx-len=%u rx-len=%u",
-				  addr, len, attempt + 1, arm_gap,
+				  "hcd-control-read setup-ack-ok %s addr=%u len=%u attempt=%u gap=%u tx-len=%u rx-len=%u",
+				  mode, addr, len, attempt + 1,
+				  report_gap,
 				  encoded_len,
 				  uh->last_rx_len);
 		}
@@ -3429,9 +3473,9 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 			if (ret) {
 				scnprintf(uh->last_probe_summary,
 					  sizeof(uh->last_probe_summary),
-					  "hcd-control-read data addr=%u len=%u attempt=%u gap=%u ret=%d pid=0x%02x setup-ack=%u",
-					  addr, len, attempt + 1,
-					  arm_gap, ret,
+					  "hcd-control-read data %s addr=%u len=%u attempt=%u gap=%u ret=%d pid=0x%02x setup-ack=%u",
+					  mode, addr, len, attempt + 1,
+					  report_gap, ret,
 					  uh->last_rx_pid,
 					  setup_seen ? 1 : 0);
 				last_ret = ret;
@@ -3468,10 +3512,11 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 					scnprintf(
 						uh->last_probe_summary,
 						sizeof(uh->last_probe_summary),
-						"hcd-control-read ok addr=%u requested=%u actual=%u attempt=%u gap=%u setup-ack=%u",
+						"hcd-control-read ok %s addr=%u requested=%u actual=%u attempt=%u gap=%u setup-ack=%u",
+						mode,
 						addr, len, copied,
 						attempt + 1,
-						arm_gap,
+						report_gap,
 						setup_seen ? 1 : 0);
 				}
 				return ret;
@@ -3479,6 +3524,9 @@ static int fj_usbhost_hcd_control_read(struct fruitjam_usbhost *uh,
 		}
 	}
 
+	scnprintf(uh->last_probe_summary, sizeof(uh->last_probe_summary),
+		  "hcd-control-read failed modes=upstream,arm-gap gaps=4,2,1,0,8,12,16,6 last-ret=%d pid=0x%02x rx-len=%u",
+		  last_ret, uh->last_rx_pid, uh->last_rx_len);
 	return last_ret;
 }
 
