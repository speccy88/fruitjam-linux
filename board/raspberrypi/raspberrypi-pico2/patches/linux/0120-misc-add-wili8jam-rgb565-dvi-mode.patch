 	writel((u32)(fj->hstx_fifo_phys + HSTX_FIFO_FIFO),
 	       fj->dma + DMA_CH_WRITE_ADDR(ch));
 	writel(words, fj->dma + DMA_CH_TRANS_COUNT(ch));
-	writel(fj_dvi_dma_ctrl(chain_to), fj->dma + DMA_CH_CTRL_TRIG(ch));
+	writel(fj_dvi_dma_ctrl(chain_to, DMA_CTRL_SIZE_WORD),
