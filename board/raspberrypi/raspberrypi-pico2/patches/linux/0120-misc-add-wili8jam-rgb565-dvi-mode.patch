+	fj_dvi_dma_update_ctrl(fj, ch, src, words, chain_to, size);
 
-	if (!fj->active_cmd_posted) {
+	if (line_done) {
 		fj->scanline = (fj->scanline + 1) % MODE_V_TOTAL_LINES;
 		if (!fj->scanline) {
 			fj->frames++;
@@ -417,10 +572,11 @@
 	fj_dvi_configure_gpio(fj);
 	fj_dvi_configure_hstx(fj);
 
