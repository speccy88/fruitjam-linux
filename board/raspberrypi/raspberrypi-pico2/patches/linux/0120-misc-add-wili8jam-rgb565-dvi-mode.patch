 }
 
+static void fj_dvi_select_mode(struct fj_dvi *fj, bool wili_mode)
+{
+	if (fj->wili_mode == wili_mode)
+		return;
+
+	fj_dvi_hw_stop(fj);
+	fj->wili_mode = wili_mode;
+	fj->active_cmd_posted = false;
+	fj->wili_stage = FJ_DVI_WILI_STAGE_PRE;
+}
