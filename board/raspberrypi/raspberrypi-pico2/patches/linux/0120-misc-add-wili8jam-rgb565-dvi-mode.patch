 	const void *src;
 	u32 words;
+	u32 size = DMA_CTRL_SIZE_WORD;
+	bool line_done = true;
 
 	if (!(status & (BIT(FJ_DVI_DMACH_PING) | BIT(FJ_DVI_DMACH_PONG))))
 		return IRQ_NONE;
@@ -366,7 +518,9 @@
 	writel(BIT(ch), fj->dma + DMA_INTR);
 	fj->dma_pong = !fj->dma_pong;
 
-	if (fj->scanline >= MODE_V_FRONT_PORCH &&
+	if (fj->wili_mode) {
+		line_done = fj_dvi_wili_next_transfer(fj, &src, &words, &size);
+	} else if (fj->scanline >= MODE_V_FRONT_PORCH &&
 	    fj->scanline < MODE_V_FRONT_PORCH + MODE_V_SYNC_WIDTH) {
 		src = fj_dvi_vblank_vsync_on;
 		words = ARRAY_SIZE(fj_dvi_vblank_vsync_on);
