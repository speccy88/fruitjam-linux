From: Codex <codex@openai.com>
Date: Thu, 18 Jun 2026 19:40:00 -0400
Subject: [PATCH] misc: add wili8jam RGB565 DVI mode

The first Fruit Jam Linux DVI path exposes a raw 640x480 RGB332 buffer for
small Linux dashboards.  wili8jam's known-working video path uses a different
contract: a 128x128 RGB565 framebuffer, HSTX RGB565 TMDS expansion, 3x pixel
scaling, and black borders centered inside the same 640x480 timing.

Add that wili8jam-compatible mode as an explicit /dev/fruitjam-dvi command set
without removing the existing raw Linux dashboard mode.  The old "show" and
"test" commands still drive the 640x480 RGB332 buffer; "wili-show",
"wili-forever", and "wili-test" select the RGB565/scaled path and reprogram the
HSTX expander before DMA starts.
---
 drivers/misc/fruitjam_dvi.c | 205 ++++++++++++++++++++++++++++++++---
 1 file changed, 182 insertions(+), 23 deletions(-)

diff --git a/drivers/misc/fruitjam_dvi.c b/drivers/misc/fruitjam_dvi.c
--- a/drivers/misc/fruitjam_dvi.c
+++ b/drivers/misc/fruitjam_dvi.c
@@ -3,8 +3,10 @@
  * Minimal Adafruit Fruit Jam RP2350 HSTX DVI helper.
  *
  * This is a bring-up display path, not a full fbdev/DRM driver. It exposes
- * /dev/fruitjam-dvi as a raw 640x480 RGB332 buffer and accepts short text
- * commands such as "pattern", "show", "start", "forever", and "stop".
+ * /dev/fruitjam-dvi as a raw 640x480 RGB332 buffer and also accepts explicit
+ * wili8jam-compatible commands.  The wili8jam mode uses a 128x128 RGB565
+ * framebuffer, HSTX RGB565 expansion, 3x scaling, and black borders inside
+ * the same 640x480 timing.
  *
  * The HSTX/DMA programming follows Raspberry Pi's RP2350
  * hstx/dvi_out_hstx_encoder Pico SDK example.
@@ -31,6 +33,10 @@
 #define FJ_DVI_HEIGHT			480u
 #define FJ_DVI_FB_SIZE			(FJ_DVI_WIDTH * FJ_DVI_HEIGHT)
 
+#define FJ_DVI_WILI_FB_WIDTH		128u
+#define FJ_DVI_WILI_FB_HEIGHT		128u
+#define FJ_DVI_WILI_SCALE		3u
+
 #define FJ_DVI_DMACH_PING		0u
 #define FJ_DVI_DMACH_PONG		1u
 #define FJ_DVI_DREQ_HSTX		52u
@@ -98,6 +104,7 @@
 #define DMA_CTRL_CHAIN_TO(v)		(((v) & 0xf) << 13)
 #define DMA_CTRL_INCR_READ		BIT(4)
 #define DMA_CTRL_SIZE_WORD		(2u << 2)
+#define DMA_CTRL_SIZE_HALFWORD		(1u << 2)
 #define DMA_CTRL_EN			BIT(0)
 
 #define TMDS_CTRL_00			0x354u
@@ -120,9 +127,18 @@
 #define MODE_H_TOTAL_PIXELS		(MODE_H_FRONT_PORCH + MODE_H_SYNC_WIDTH + MODE_H_BACK_PORCH + MODE_H_ACTIVE_PIXELS)
 #define MODE_V_TOTAL_LINES		(MODE_V_FRONT_PORCH + MODE_V_SYNC_WIDTH + MODE_V_BACK_PORCH + MODE_V_ACTIVE_LINES)
 #define MODE_V_ACTIVE_START		(MODE_V_TOTAL_LINES - MODE_V_ACTIVE_LINES)
+#define FJ_DVI_WILI_ACTIVE_START	(MODE_V_SYNC_WIDTH + MODE_V_BACK_PORCH)
+#define FJ_DVI_WILI_ACTIVE_END		(FJ_DVI_WILI_ACTIVE_START + MODE_V_ACTIVE_LINES)
+#define FJ_DVI_WILI_CONTENT_LINES	(FJ_DVI_WILI_FB_HEIGHT * FJ_DVI_WILI_SCALE)
+#define FJ_DVI_WILI_H_BORDER		((MODE_H_ACTIVE_PIXELS - (FJ_DVI_WILI_FB_WIDTH * FJ_DVI_WILI_SCALE)) / 2u)
+#define FJ_DVI_WILI_V_BORDER		((MODE_V_ACTIVE_LINES - FJ_DVI_WILI_CONTENT_LINES) / 2u)
+#define FJ_DVI_WILI_CONTENT_START	(FJ_DVI_WILI_ACTIVE_START + FJ_DVI_WILI_V_BORDER)
+#define FJ_DVI_WILI_CONTENT_END		(FJ_DVI_WILI_CONTENT_START + FJ_DVI_WILI_CONTENT_LINES)
+#define FJ_DVI_WILI_FB_SIZE		(FJ_DVI_WILI_FB_WIDTH * FJ_DVI_WILI_FB_HEIGHT)
 
 #define HSTX_CMD_RAW_REPEAT		(0x1u << 12)
 #define HSTX_CMD_TMDS			(0x2u << 12)
+#define HSTX_CMD_TMDS_REPEAT		(0x3u << 12)
 #define HSTX_CMD_NOP			(0xfu << 12)
 
 static u32 fj_dvi_vblank_vsync_off[] = {
@@ -157,8 +173,47 @@
 	HSTX_CMD_TMDS | MODE_H_ACTIVE_PIXELS,
 };
 
+static u32 fj_dvi_wili_active_pre[] = {
+	HSTX_CMD_RAW_REPEAT | MODE_H_FRONT_PORCH,
+	SYNC_V1_H1,
+	HSTX_CMD_NOP,
+	HSTX_CMD_RAW_REPEAT | MODE_H_SYNC_WIDTH,
+	SYNC_V1_H0,
+	HSTX_CMD_NOP,
+	HSTX_CMD_RAW_REPEAT | MODE_H_BACK_PORCH,
+	SYNC_V1_H1,
+	HSTX_CMD_TMDS_REPEAT | FJ_DVI_WILI_H_BORDER,
+	0x00000000,
+	HSTX_CMD_TMDS | (FJ_DVI_WILI_FB_WIDTH * FJ_DVI_WILI_SCALE),
+};
+
+static u32 fj_dvi_wili_active_post[] = {
+	HSTX_CMD_TMDS_REPEAT | FJ_DVI_WILI_H_BORDER,
+	0x00000000,
+};
+
+static u32 fj_dvi_wili_active_black[] = {
+	HSTX_CMD_RAW_REPEAT | MODE_H_FRONT_PORCH,
+	SYNC_V1_H1,
+	HSTX_CMD_NOP,
+	HSTX_CMD_RAW_REPEAT | MODE_H_SYNC_WIDTH,
+	SYNC_V1_H0,
+	HSTX_CMD_NOP,
+	HSTX_CMD_RAW_REPEAT | MODE_H_BACK_PORCH,
+	SYNC_V1_H1,
+	HSTX_CMD_TMDS_REPEAT | MODE_H_ACTIVE_PIXELS,
+	0x00000000,
+};
+
 static u8 fj_dvi_framebuf[FJ_DVI_FB_SIZE] __aligned(4);
+static u16 fj_dvi_wili_framebuf[FJ_DVI_WILI_FB_SIZE] __aligned(4);
 
+enum fj_dvi_wili_stage {
+	FJ_DVI_WILI_STAGE_PRE,
+	FJ_DVI_WILI_STAGE_PIXELS,
+	FJ_DVI_WILI_STAGE_POST,
+};
+
 struct fj_dvi {
 	struct device *dev;
 	struct miscdevice miscdev;
@@ -176,9 +231,11 @@
 	u32 scanline;
 	u32 frames;
 	u32 frames_left;
+	u8 wili_stage;
 	bool dma_pong;
 	bool active_cmd_posted;
 	bool running;
+	bool wili_mode;
 };
 
 static void __iomem *fj_dvi_ioremap_byname(struct platform_device *pdev,
@@ -198,6 +255,13 @@
 	return ((r & 0xc0) >> 6) | ((g & 0xe0) >> 3) | (b & 0xe0);
 }
 
+static u16 fj_dvi_rgb565(u8 r, u8 g, u8 b)
+{
+	return ((u16)(r & 0xf8) << 8) |
+	       ((u16)(g & 0xfc) << 3) |
+	       ((u16)b >> 3);
+}
+
 static void fj_dvi_fill_clear(u8 colour)
 {
 	memset(fj_dvi_framebuf, colour, sizeof(fj_dvi_framebuf));
@@ -227,6 +291,30 @@
 	}
 }
 
+static void fj_dvi_fill_wili_pattern(void)
+{
+	static const u16 bars[] = {
+		0x0000, 0x001f, 0x07e0, 0xf800, 0x07ff, 0xf81f, 0xffe0, 0xffff,
+	};
+	u32 x;
+	u32 y;
+
+	for (y = 0; y < FJ_DVI_WILI_FB_HEIGHT; y++) {
+		for (x = 0; x < FJ_DVI_WILI_FB_WIDTH; x++) {
+			u16 c;
+
+			if (y < 24) {
+				c = bars[(x * ARRAY_SIZE(bars)) / FJ_DVI_WILI_FB_WIDTH];
+			} else if (y < 112) {
+				c = fj_dvi_rgb565((u8)(x * 2u), (u8)(y * 2u), (u8)(x + y));
+			} else {
+				c = ((x / 8u) ^ (y / 8u)) & 1u ? 0xffff : 0x0000;
+			}
+			fj_dvi_wili_framebuf[y * FJ_DVI_WILI_FB_WIDTH + x] = c;
+		}
+	}
+}
+
 static int fj_dvi_unreset(struct fj_dvi *fj, u32 bitno)
 {
 	u32 bit = BIT(bitno);
@@ -276,18 +364,33 @@
 	u32 lane;
 
 	writel(0, fj->hstx_ctrl + HSTX_CTRL_CSR);
-	writel(HSTX_EXPAND_TMDS_L2_NBITS(2) |
-	       HSTX_EXPAND_TMDS_L2_ROT(0) |
-	       HSTX_EXPAND_TMDS_L1_NBITS(2) |
-	       HSTX_EXPAND_TMDS_L1_ROT(29) |
-	       HSTX_EXPAND_TMDS_L0_NBITS(1) |
-	       HSTX_EXPAND_TMDS_L0_ROT(26),
-	       fj->hstx_ctrl + HSTX_CTRL_EXPAND_TMDS);
-	writel(HSTX_EXPAND_SHIFT_ENC_N(4) |
+	if (fj->wili_mode) {
+		writel(HSTX_EXPAND_TMDS_L2_NBITS(4) |
+		       HSTX_EXPAND_TMDS_L2_ROT(8) |
+		       HSTX_EXPAND_TMDS_L1_NBITS(5) |
+		       HSTX_EXPAND_TMDS_L1_ROT(3) |
+		       HSTX_EXPAND_TMDS_L0_NBITS(4) |
+		       HSTX_EXPAND_TMDS_L0_ROT(29),
+		       fj->hstx_ctrl + HSTX_CTRL_EXPAND_TMDS);
+		writel(HSTX_EXPAND_SHIFT_ENC_N(FJ_DVI_WILI_SCALE) |
+		       HSTX_EXPAND_SHIFT_ENC(16) |
+		       HSTX_EXPAND_SHIFT_RAW_N(1) |
+		       HSTX_EXPAND_SHIFT_RAW(0),
+		       fj->hstx_ctrl + HSTX_CTRL_EXPAND_SHIFT);
+	} else {
+		writel(HSTX_EXPAND_TMDS_L2_NBITS(2) |
+		       HSTX_EXPAND_TMDS_L2_ROT(0) |
+		       HSTX_EXPAND_TMDS_L1_NBITS(2) |
+		       HSTX_EXPAND_TMDS_L1_ROT(29) |
+		       HSTX_EXPAND_TMDS_L0_NBITS(1) |
+		       HSTX_EXPAND_TMDS_L0_ROT(26),
+		       fj->hstx_ctrl + HSTX_CTRL_EXPAND_TMDS);
+		writel(HSTX_EXPAND_SHIFT_ENC_N(4) |
 	       HSTX_EXPAND_SHIFT_ENC(8) |
 	       HSTX_EXPAND_SHIFT_RAW_N(1) |
 	       HSTX_EXPAND_SHIFT_RAW(0),
 	       fj->hstx_ctrl + HSTX_CTRL_EXPAND_SHIFT);
+	}
 
 	for (lane = 0; lane < 8; lane++)
 		writel(0, fj->hstx_ctrl + HSTX_CTRL_BIT(lane));
@@ -314,12 +417,12 @@
 	       fj->hstx_ctrl + HSTX_CTRL_CSR);
 }
 
-static u32 fj_dvi_dma_ctrl(u32 chain_to)
+static u32 fj_dvi_dma_ctrl(u32 chain_to, u32 size)
 {
 	return DMA_CTRL_TREQ(FJ_DVI_DREQ_HSTX) |
 	       DMA_CTRL_CHAIN_TO(chain_to) |
 	       DMA_CTRL_INCR_READ |
-	       DMA_CTRL_SIZE_WORD |
+	       size |
 	       DMA_CTRL_EN;
 }
 
