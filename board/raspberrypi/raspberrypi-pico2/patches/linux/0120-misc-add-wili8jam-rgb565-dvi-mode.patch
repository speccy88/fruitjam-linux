 	writel((u32)virt_to_phys((void *)src), fj->dma + DMA_CH_READ_ADDR(ch));
-	writel(words, fj->dma + DMA_CH_TRANS_COUNT(ch));
+	writel(count, fj->dma + DMA_CH_TRANS_COUNT(ch));
+	writel(fj_dvi_dma_ctrl(chain_to, size), fj->dma + DMA_CH_CTRL_TRIG(ch));
 }
 
 static void fj_dvi_hw_stop_irq(struct fj_dvi *fj)
@@ -352,13 +457,60 @@
 	fj->running = false;
 }
 
+static bool fj_dvi_wili_next_transfer(struct fj_dvi *fj, const void **src,
+				      u32 *count, u32 *size)
+{
+	u32 line = fj->scanline;
+	u32 row;
+
+	*size = DMA_CTRL_SIZE_WORD;
+	if (line < MODE_V_SYNC_WIDTH) {
+		*src = fj_dvi_vblank_vsync_on;
+		*count = ARRAY_SIZE(fj_dvi_vblank_vsync_on);
+		return true;
+	}
+	if (line < FJ_DVI_WILI_ACTIVE_START || line >= FJ_DVI_WILI_ACTIVE_END) {
+		*src = fj_dvi_vblank_vsync_off;
+		*count = ARRAY_SIZE(fj_dvi_vblank_vsync_off);
+		return true;
+	}
+	if (line < FJ_DVI_WILI_CONTENT_START || line >= FJ_DVI_WILI_CONTENT_END) {
+		*src = fj_dvi_wili_active_black;
+		*count = ARRAY_SIZE(fj_dvi_wili_active_black);
+		return true;
+	}
+
+	switch (fj->wili_stage) {
+	case FJ_DVI_WILI_STAGE_PRE:
+		*src = fj_dvi_wili_active_pre;
+		*count = ARRAY_SIZE(fj_dvi_wili_active_pre);
+		fj->wili_stage = FJ_DVI_WILI_STAGE_PIXELS;
+		return false;
+	case FJ_DVI_WILI_STAGE_PIXELS:
+		row = (line - FJ_DVI_WILI_CONTENT_START) / FJ_DVI_WILI_SCALE;
+		*src = &fj_dvi_wili_framebuf[row * FJ_DVI_WILI_FB_WIDTH];
+		*count = FJ_DVI_WILI_FB_WIDTH;
+		*size = DMA_CTRL_SIZE_HALFWORD;
+		fj->wili_stage = FJ_DVI_WILI_STAGE_POST;
+		return false;
+	default:
+		*src = fj_dvi_wili_active_post;
+		*count = ARRAY_SIZE(fj_dvi_wili_active_post);
+		fj->wili_stage = FJ_DVI_WILI_STAGE_PRE;
+		return true;
+	}
+}
