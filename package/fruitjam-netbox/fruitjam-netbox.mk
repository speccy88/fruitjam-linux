FRUITJAM_NETBOX_VERSION = 1.37.0
FRUITJAM_NETBOX_SOURCE = busybox-$(FRUITJAM_NETBOX_VERSION).tar.bz2
FRUITJAM_NETBOX_SITE = https://busybox.net/downloads
FRUITJAM_NETBOX_LICENSE = GPL-2.0
FRUITJAM_NETBOX_LICENSE_FILES = LICENSE
FRUITJAM_NETBOX_DEPENDENCIES = busybox
FRUITJAM_NETBOX_CFLAGS = $(TARGET_CFLAGS)
FRUITJAM_NETBOX_LDFLAGS = $(TARGET_LDFLAGS)

FRUITJAM_NETBOX_MAKE_ENV = \
	$(TARGET_MAKE_ENV) \
	CFLAGS="$(FRUITJAM_NETBOX_CFLAGS)"

FRUITJAM_NETBOX_MAKE_OPTS = \
	AR="$(TARGET_AR)" \
	NM="$(TARGET_NM)" \
	RANLIB="$(TARGET_RANLIB)" \
	CC="$(TARGET_CC)" \
	ARCH=$(NORMALIZED_ARCH) \
	EXTRA_LDFLAGS="$(FRUITJAM_NETBOX_LDFLAGS)" \
	CROSS_COMPILE="$(TARGET_CROSS)" \
	SKIP_STRIP=y

define FRUITJAM_NETBOX_ENABLE
	$(SED) '/^\(# \)\?$(1)\>/d' $(@D)/.config
	echo '$(1)=y' >> $(@D)/.config
endef

define FRUITJAM_NETBOX_DISABLE
	$(SED) '/^\(# \)\?$(1)\>/d' $(@D)/.config
	echo '# $(1) is not set' >> $(@D)/.config
endef

define FRUITJAM_NETBOX_SET
	$(SED) '/^\(# \)\?$(1)\>/d' $(@D)/.config
	echo '$(1)=$(2)' >> $(@D)/.config
endef

define FRUITJAM_NETBOX_RESET_CONFIG
	$(FRUITJAM_NETBOX_MAKE_ENV) $(MAKE) -C $(@D) \
		$(FRUITJAM_NETBOX_MAKE_OPTS) allnoconfig
	$(call FRUITJAM_NETBOX_ENABLE,CONFIG_STATIC)
	$(call FRUITJAM_NETBOX_ENABLE,CONFIG_NOMMU)
	$(call FRUITJAM_NETBOX_ENABLE,CONFIG_LFS)
	$(call FRUITJAM_NETBOX_ENABLE,CONFIG_BUSYBOX)
	$(call FRUITJAM_NETBOX_ENABLE,CONFIG_FEATURE_PREFER_APPLETS)
endef

define FRUITJAM_NETBOX_FINISH_CONFIG
	yes "" | $(FRUITJAM_NETBOX_MAKE_ENV) $(MAKE) -C $(@D) \
		$(FRUITJAM_NETBOX_MAKE_OPTS) oldconfig
	$(FRUITJAM_NETBOX_MAKE_ENV) $(MAKE) -C $(@D) \
		$(FRUITJAM_NETBOX_MAKE_OPTS) clean
endef

define FRUITJAM_NETBOX_BUILD_ONE
	$(call FRUITJAM_NETBOX_RESET_CONFIG)
	$(FRUITJAM_NETBOX_CONFIG_$(1))
	$(call FRUITJAM_NETBOX_FINISH_CONFIG)
	$(FRUITJAM_NETBOX_MAKE_ENV) $(MAKE) -C $(@D) \
		$(FRUITJAM_NETBOX_MAKE_OPTS) busybox
	cp $(@D)/busybox $(@D)/$(2)
	$(TARGET_CROSS)flthdr -s 4096 $(@D)/$(2)
endef

