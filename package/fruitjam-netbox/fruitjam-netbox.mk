define FRUITJAM_NETBOX_INSTALL_TARGET_CMDS
	$(INSTALL) -D -m 4755 $(@D)/fruitjam-busybox $(TARGET_DIR)/bin/busybox
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-hush $(TARGET_DIR)/usr/bin/hush
	find $(TARGET_DIR)/bin $(TARGET_DIR)/sbin $(TARGET_DIR)/usr/bin \
		$(TARGET_DIR)/usr/sbin -type l | while read link; do \
		target=$$(readlink "$$link"); \
		case "$$target" in busybox|../bin/busybox|../../bin/busybox) \
			rm -f "$$link";; \
		esac; \
	done
	ln -sf busybox $(TARGET_DIR)/bin/sh
	ln -sf ../usr/bin/hush $(TARGET_DIR)/bin/hush
	ln -sf ../bin/busybox $(TARGET_DIR)/sbin/init
	rm -f $(TARGET_DIR)/bin/netbox \
		$(TARGET_DIR)/bin/cat \
		$(TARGET_DIR)/bin/echo \
		$(TARGET_DIR)/bin/ls \
		$(TARGET_DIR)/bin/mkdir \
		$(TARGET_DIR)/bin/mount \
		$(TARGET_DIR)/usr/bin/printf \
		$(TARGET_DIR)/bin/sleep \
		$(TARGET_DIR)/bin/umount \
		$(TARGET_DIR)/bin/vi \
		$(TARGET_DIR)/bin/ps \
		$(TARGET_DIR)/usr/bin/killall \
		$(TARGET_DIR)/sbin/ifconfig \
		$(TARGET_DIR)/bin/netstat
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-corebox $(TARGET_DIR)/bin/corebox
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-grep $(TARGET_DIR)/bin/grep
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-sed $(TARGET_DIR)/bin/sed
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-df $(TARGET_DIR)/bin/df
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-head $(TARGET_DIR)/usr/bin/head
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-tail $(TARGET_DIR)/usr/bin/tail
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-wc $(TARGET_DIR)/usr/bin/wc
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-cut $(TARGET_DIR)/usr/bin/cut
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-tr $(TARGET_DIR)/usr/bin/tr
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-uname $(TARGET_DIR)/bin/uname
	ln -sf grep $(TARGET_DIR)/bin/egrep
	ln -sf grep $(TARGET_DIR)/bin/fgrep
	for app in chgrp chmod chown cp date dd dmesg false \
		getopt hostname kill ln mknod more mv ping printenv pwd rm \
		rmdir stty sync touch true; do \
		ln -sf corebox $(TARGET_DIR)/bin/$$app; \
	done
	for app in basename dirname env tee test which xargs \
		yes; do \
		ln -sf ../../bin/corebox $(TARGET_DIR)/usr/bin/$$app; \
	done
	for app in halt poweroff reboot; do \
		ln -sf ../bin/corebox $(TARGET_DIR)/sbin/$$app; \
	done
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-cat $(TARGET_DIR)/bin/cat
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-echo $(TARGET_DIR)/bin/echo
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-ls $(TARGET_DIR)/bin/ls
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-mkdir $(TARGET_DIR)/bin/mkdir
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-mount $(TARGET_DIR)/bin/mount
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-printf $(TARGET_DIR)/usr/bin/printf
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-sleep $(TARGET_DIR)/bin/sleep
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-umount $(TARGET_DIR)/bin/umount
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-vi $(TARGET_DIR)/bin/vi
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-ps $(TARGET_DIR)/bin/ps
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-killall $(TARGET_DIR)/usr/bin/killall
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-ifconfig $(TARGET_DIR)/sbin/ifconfig
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-netstat $(TARGET_DIR)/bin/netstat
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-nc $(TARGET_DIR)/usr/bin/nc
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-httpd $(TARGET_DIR)/usr/sbin/httpd
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-ftpd $(TARGET_DIR)/usr/sbin/ftpd
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-tftp $(TARGET_DIR)/usr/bin/tftp
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-tftpd $(TARGET_DIR)/usr/sbin/tftpd
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-sv $(TARGET_DIR)/usr/bin/tcpsvd
		$(INSTALL) -D -m 0755 $(@D)/fruitjam-sv $(TARGET_DIR)/usr/bin/udpsvd
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-telnetd $(TARGET_DIR)/usr/sbin/telnetd
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-telnet $(TARGET_DIR)/usr/bin/telnet
	$(INSTALL) -D -m 0755 $(@D)/fruitjam-wget $(TARGET_DIR)/usr/bin/wget
endef

